---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Lightbox from "../components/Lightbox.astro";

interface Props {
  title: string;
  description?: string;
  /** Ruta relativa a /public de una imagen custom para esta página. Si no se pasa, usa /og-image.svg. */
  ogImage?: string;
  /** No indexar (p. ej. borradores / vistas previas internas). */
  noindex?: boolean;
}

const {
  title,
  description = "Escuela de Simbología, Espagiria y Tradición Hermética. Cursos online en vivo dirigidos por Emanuel Mari. Alquimia. Centro de estudios tradicionales.",
  ogImage = "/og-image.svg",
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://www.tradicionmisticayhermetica.com");
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageAbsolute = new URL(ogImage, siteUrl).toString();
const fullTitle = `${title} · Tradición Mística y Hermética`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#07060d" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* Favicon: SVG escalable (navegadores modernos) */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {/* Para iOS / añadir a home screen */}
    <link rel="apple-touch-icon" href="/favicon.svg" />
    {/* Color de "mask icon" en Safari pinned tabs */}
    <link rel="mask-icon" href="/favicon.svg" color="#d4af37" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* Open Graph (Facebook, WhatsApp, LinkedIn, Slack, Discord) */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Tradición Mística y Hermética" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Sello solar alquímico sobre fondo nocturno con el nombre Tradición Mística y Hermética." />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500;600&display=swap"
    />
  </head>

  <body class="min-h-screen flex flex-col">
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <Lightbox />
  </body>
</html>
