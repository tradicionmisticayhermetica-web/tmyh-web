---
/**
 * Layout para paginas del panel /area-reservada.
 *
 * Diferencia clave vs BaseLayout:
 *   - No incluye Navbar/Footer publicos.
 *   - Tiene su propio header + sidebar.
 *   - Hace guard de sesion en client-side (redirige a /login si no hay
 *     admin valido).
 *
 * Uso:
 *   ---
 *   import AdminLayout from "../../layouts/AdminLayout.astro";
 *   ---
 *   <AdminLayout title="Mensajes" active="mensajes">
 *     <!-- contenido -->
 *   </AdminLayout>
 */
import "../styles/global.css";
import LoaderGlobal from "../components/LoaderGlobal.astro";
import GoogleTagManager from "../components/GoogleTagManager.astro";

interface Props {
  title: string;
  /** Item activo del sidebar: "dashboard" | "mensajes" | "newsletter" | ... */
  active?: string;
}

const { title, active = "dashboard" } = Astro.props;

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const hrefSitioPublico = baseUrl ? `${baseUrl}/` : "/";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#07060d" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} · Área Reservada</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500;600&display=swap"
    />

    <GoogleTagManager />
  </head>

  <body class="min-h-screen flex flex-col">
    <GoogleTagManager body />
    {/* Pantalla de carga mientras valida sesion. Reutiliza las clases
        animadas del componente LoaderGlobal para mantener una sola
        identidad visual de "estado de espera" en todo el sitio. */}
    <div
      id="admin-loading"
      class="fixed inset-0 z-50 flex items-center justify-center bg-night-900"
      role="status"
      aria-live="polite"
      aria-label="Verificando acceso"
    >
      <div class="card-altar px-9 py-8 text-center min-w-[300px]">
        <div class="loader-orb" aria-hidden="true">
          <span class="loader-orb-particle m">☿</span>
          <span class="loader-orb-particle a">🜍</span>
          <span class="loader-orb-particle s">🜔</span>
          <span class="loader-orb-sun">☉</span>
        </div>
        <p class="mt-6 text-xs tracking-[0.22em] uppercase text-parchment-200">
          Verificando acceso
        </p>
      </div>
    </div>

    <div id="admin-shell" class="hidden flex-1 flex flex-col lg:flex-row">
      {/* Sidebar */}
      <aside
        class="lg:w-64 lg:min-h-screen border-b lg:border-b-0 lg:border-r border-gold-400/15 bg-night-950/60 flex lg:flex-col"
      >
        <div class="px-6 py-5 border-b border-gold-400/10 flex-1 lg:flex-none">
          <a
            href="/area-reservada"
            class="flex items-center gap-3 group"
            aria-label="Inicio del panel"
          >
            <span
              class="text-xl text-gold-400 group-hover:scale-110 transition-transform"
              >☉</span
            >
            <div>
              <div
                class="font-display text-sm tracking-widest text-parchment-50"
              >
                Área Reservada
              </div>
              <div
                class="text-[10px] tracking-[0.2em] uppercase text-parchment-400"
              >
                Tradición M&H
              </div>
            </div>
          </a>
        </div>

        <nav class="flex lg:flex-col px-3 py-3 lg:py-5 gap-1 overflow-x-auto">
          <a
            href={hrefSitioPublico}
            target="_blank"
            rel="noopener noreferrer"
            class="admin-nav-link border border-gold-400/15 bg-gold-400/[0.04] mb-0.5"
            title="Abrir el sitio público en una pestaña nueva"
          >
            <span class="admin-nav-icon">↗</span>
            <span>Ir al sitio</span>
          </a>
          <a
            href="/area-reservada"
            data-nav="dashboard"
            class="admin-nav-link"
          >
            <span class="admin-nav-icon">◇</span>
            <span>Dashboard</span>
          </a>
          <a
            href="/area-reservada/mensajes"
            data-nav="mensajes"
            class="admin-nav-link"
          >
            <span class="admin-nav-icon">✉</span>
            <span>Mensajes</span>
          </a>
          <a
            href="/area-reservada/blog"
            data-nav="blog"
            class="admin-nav-link"
          >
            <span class="admin-nav-icon">✍</span>
            <span>Blog</span>
          </a>
          <a
            href="/area-reservada/newsletter"
            data-nav="newsletter"
            class="admin-nav-link"
          >
            <span class="admin-nav-icon">✦</span>
            <span>Newsletter</span>
          </a>
          <a
            href="/area-reservada/cursos"
            data-nav="cursos"
            class="admin-nav-link"
          >
            <span class="admin-nav-icon">⚝</span>
            <span>Cursos</span>
          </a>
          <div class="hidden lg:block lg:my-2 border-t border-gold-400/10"></div>
          <a
            href="/area-reservada/cuenta"
            data-nav="cuenta"
            class="admin-nav-link"
          >
            <span class="admin-nav-icon">◉</span>
            <span>Mi cuenta</span>
          </a>
        </nav>

        <div
          class="hidden lg:block mt-auto px-5 py-4 border-t border-gold-400/10 text-xs"
        >
          <div class="text-parchment-400 mb-1">Sesión</div>
          <div class="text-parchment-100 truncate" id="admin-user-email">
            ...
          </div>
          <div
            class="text-[10px] text-gold-300 uppercase tracking-widest mt-1"
            id="admin-user-rol"
          >
          </div>
          <button
            id="btn-cerrar-sesion"
            class="mt-3 text-[11px] uppercase tracking-widest text-parchment-300 hover:text-gold-300 transition"
          >
            Cerrar sesión →
          </button>
        </div>

        <div
          class="lg:hidden flex items-center px-3 py-2 border-l border-gold-400/10"
        >
          <button
            id="btn-cerrar-sesion-mobile"
            class="text-[11px] uppercase tracking-widest text-parchment-300 hover:text-gold-300 transition px-3 py-1.5"
            aria-label="Cerrar sesión"
          >
            Salir
          </button>
        </div>
      </aside>

      {/* Contenido */}
      <main class="flex-1 px-6 lg:px-10 py-8 lg:py-10">
        <div class="max-w-5xl mx-auto">
          <slot />
        </div>
      </main>
    </div>

    <LoaderGlobal />

    <style is:global>
      .admin-nav-link {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.6rem 0.85rem;
        font-family: var(--font-sans);
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: 0.06em;
        color: var(--color-parchment-200);
        border-radius: 2px;
        white-space: nowrap;
        transition:
          color 180ms ease,
          background-color 180ms ease;
      }
      .admin-nav-link:hover {
        color: var(--color-gold-300);
        background-color: rgb(230 196 100 / 0.06);
      }
      .admin-nav-link.is-active {
        color: var(--color-gold-300);
        background-color: rgb(230 196 100 / 0.08);
        box-shadow: inset 2px 0 0 var(--color-gold-400);
      }
      .admin-nav-icon {
        font-size: 0.95rem;
        color: var(--color-gold-400);
        opacity: 0.8;
        width: 1rem;
        text-align: center;
      }
      .admin-nav-disabled {
        opacity: 0.4;
        pointer-events: none;
      }
    </style>

    <script define:vars={{ active }}>
      // Marcar item activo del sidebar
      document.querySelectorAll(".admin-nav-link").forEach((el) => {
        if (el.getAttribute("data-nav") === active) {
          el.classList.add("is-active");
        }
      });
    </script>

    <script>
      import { requerirAdmin, cerrarSesion } from "../lib/auth";

      // El loader global (window.__tmyhLoader) lo configura el componente
      // <LoaderGlobal /> y queda disponible apenas se parsea el HTML, antes
      // de que este script termine el await de auth.

      const loading = document.getElementById("admin-loading");
      const shell = document.getElementById("admin-shell");

      const perfil = await requerirAdmin();
      if (perfil) {
        loading?.remove();
        shell?.classList.remove("hidden");

        const emailEl = document.getElementById("admin-user-email");
        if (emailEl) emailEl.textContent = perfil.email;
        const rolEl = document.getElementById("admin-user-rol");
        if (rolEl)
          rolEl.textContent =
            perfil.rol === "super_admin"
              ? "Super admin"
              : perfil.rol === "admin"
                ? "Admin"
                : perfil.rol;

        const handleCerrar = async () => {
          await cerrarSesion();
          window.location.href = "/login";
        };

        document
          .getElementById("btn-cerrar-sesion")
          ?.addEventListener("click", handleCerrar);
        document
          .getElementById("btn-cerrar-sesion-mobile")
          ?.addEventListener("click", handleCerrar);
      }
    </script>
  </body>
</html>
