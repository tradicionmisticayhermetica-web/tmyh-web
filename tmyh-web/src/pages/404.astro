---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Página no encontrada" description="La página que buscás no existe o fue movida.">
  <section class="py-32">
    <div class="container-prose max-w-xl text-center">
      <div class="text-8xl text-[color:var(--color-gold-500)] opacity-50 mb-6">⚯</div>
      <span class="title-eyebrow">Error 404</span>
      <h1 class="text-4xl md:text-5xl font-display mt-6 mb-6">
        Esta senda no existe
      </h1>
      <p class="text-lg font-serif text-parchment-200 mb-10">
        La página que buscás no se encuentra, o el camino se ha cerrado.
      </p>
      <a href="/" class="btn-gold">Volver al inicio</a>
    </div>
  </section>
</BaseLayout>