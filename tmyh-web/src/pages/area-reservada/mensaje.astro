---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Mensaje" active="mensajes">
  <a
    href="/area-reservada/mensajes"
    class="text-xs uppercase tracking-widest text-parchment-300 hover:text-gold-300 transition inline-flex items-center gap-2 mb-6"
  >
    ← Volver a la bandeja
  </a>

  <div id="estado-carga" class="card-altar p-12 text-center">
    <div class="text-2xl text-gold-400 animate-soft-pulse">☉</div>
    <p class="mt-3 text-base text-parchment-200 font-serif italic">
      Cargando mensaje…
    </p>
  </div>

  <div id="estado-error" class="card-altar p-12 text-center hidden">
    <div class="text-2xl text-wine-600 mb-3">⚠</div>
    <p class="font-display text-lg text-parchment-50">
      No se pudo cargar el mensaje
    </p>
    <p class="text-sm text-parchment-300 mt-2 font-serif" id="error-detalle">
    </p>
    <a
      href="/area-reservada/mensajes"
      class="btn-ghost mt-6 inline-flex"
    >
      Volver
    </a>
  </div>

  <div id="contenido" class="hidden space-y-6">
    {/* Datos del visitante */}
    <section class="card-altar p-7 lg:p-8">
      <div class="flex items-start justify-between gap-6 flex-wrap">
        <div>
          <p class="title-eyebrow">Consulta</p>
          <h1 class="font-display text-2xl text-parchment-50 mt-3" id="m-nombre">
          </h1>
          <p
            class="text-base text-gold-300 mt-1 font-serif italic"
            id="m-curso"
          >
          </p>
        </div>
        <div class="text-right">
          <div class="text-[11px] text-parchment-400 uppercase tracking-widest">
            <span id="m-fecha"></span>
          </div>
        </div>
      </div>

      <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3 text-sm">
        <div>
          <div class="text-[10px] uppercase tracking-widest text-parchment-400">
            Email
          </div>
          <a
            id="m-email"
            href="#"
            class="link-subtle text-sm break-all"
          ></a>
        </div>
        <div>
          <div class="text-[10px] uppercase tracking-widest text-parchment-400">
            Teléfono
          </div>
          <div id="m-telefono" class="text-parchment-100"></div>
        </div>
        <div>
          <div class="text-[10px] uppercase tracking-widest text-parchment-400">
            Newsletter
          </div>
          <div id="m-newsletter" class="text-parchment-100"></div>
        </div>
        <div>
          <div class="text-[10px] uppercase tracking-widest text-parchment-400">
            Origen
          </div>
          <div id="m-origen" class="text-parchment-100"></div>
        </div>
      </div>

      <div class="ornament my-6" aria-hidden="true">
        <span>☉</span>
      </div>

      <div>
        <div
          class="text-[10px] uppercase tracking-widest text-parchment-400 mb-3"
        >
          Mensaje
        </div>
        <div
          id="m-mensaje"
          class="font-serif text-lg text-parchment-100 bg-night-950/40 border-l-2 border-gold-400 pl-5 py-3 whitespace-pre-wrap"
        >
        </div>
      </div>
    </section>

    <section class="card-altar p-6 lg:p-7">
      <div class="flex items-center gap-3 flex-wrap">
        <button id="btn-papelera" type="button" class="btn-ghost border border-wine-500/35">
          Mover a papelera
        </button>
        <button id="btn-borrar" type="button" class="btn-ghost border border-wine-500/55 text-wine-300">
          Eliminar definitivo
        </button>
      </div>
      <div id="status-msg" class="hidden mt-4 text-sm font-serif italic" role="status" aria-live="polite"></div>
    </section>

    {/* Aviso */}
    <section class="card-altar p-6 lg:p-7">
      <p class="font-serif text-base text-parchment-200 leading-relaxed">
        Los mensajes que estás viendo también te llegan a tu casilla de email.
        Respondelos desde ahí, acá no se almacena la conversación, así podés
        llevar el ida y vuelta de la charla con el alumno.
      </p>
    </section>
  </div>

  <script>
    import {
      obtenerMensaje,
      moverMensajeAPapelera,
      eliminarMensajeDefinitivo,
      formatearFecha,
      nombreCompleto,
      type MensajeContacto,
    } from "../../lib/admin";

    const statusMsg = document.getElementById("status-msg");
    let mensajeActual: MensajeContacto | null = null;

    function setStatus(msg: string, tipo: "ok" | "error" | "info") {
      if (!statusMsg) return;
      statusMsg.textContent = msg;
      statusMsg.classList.remove("hidden", "text-gold-300", "text-wine-500", "text-parchment-300");
      statusMsg.classList.add(tipo === "ok" ? "text-gold-300" : tipo === "error" ? "text-wine-500" : "text-parchment-300");
    }

    function confirmar(msg: string): Promise<boolean> {
      return new Promise((resolve) => {
        const overlay = document.createElement("div");
        overlay.className = "fixed inset-0 z-[998] flex items-center justify-center bg-night-950/80 backdrop-blur-sm";
        overlay.innerHTML = `
          <div class="card-altar p-8 max-w-md mx-4 space-y-5">
            <p class="font-serif text-base text-parchment-100 leading-relaxed">${msg}</p>
            <div class="flex gap-3 justify-end">
              <button id="conf-cancel" class="btn-ghost text-sm">Cancelar</button>
              <button id="conf-ok" class="btn-gold text-sm">Confirmar</button>
            </div>
          </div>`;
        document.body.appendChild(overlay);
        overlay.querySelector("#conf-ok")?.addEventListener("click", () => { overlay.remove(); resolve(true); });
        overlay.querySelector("#conf-cancel")?.addEventListener("click", () => { overlay.remove(); resolve(false); });
        overlay.addEventListener("click", (e) => { if (e.target === overlay) { overlay.remove(); resolve(false); } });
      });
    }

    function setText(id: string, value: string) {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    }

    function setHref(id: string, href: string) {
      const el = document.getElementById(id);
      if (el) (el as HTMLAnchorElement).href = href;
    }

    function show(id: string) {
      document.getElementById(id)?.classList.remove("hidden");
    }
    function hide(id: string) {
      document.getElementById(id)?.classList.add("hidden");
    }

    function pintar(m: MensajeContacto) {
      setText("m-nombre", nombreCompleto(m));
      setText("m-curso", m.curso_interes ?? "Sin especificar curso");
      setText("m-email", m.email);
      setHref("m-email", `mailto:${m.email}`);
      setText("m-telefono", m.telefono ?? "—");
      setText("m-newsletter", m.newsletter_optin ? "Sí" : "No");
      setText("m-origen", m.origen);
      setText("m-fecha", formatearFecha(m.creado_en));
      setText("m-mensaje", m.mensaje);

    }

    (async () => {
      const params = new URLSearchParams(window.location.search);
      const id = params.get("id");

      if (!id) {
        hide("estado-carga");
        show("estado-error");
        setText("error-detalle", "No se especificó un ID de mensaje en la URL.");
        return;
      }

      const m = await obtenerMensaje(id);
      if (!m) {
        hide("estado-carga");
        show("estado-error");
        setText(
          "error-detalle",
          "El mensaje no existe o no tenés permisos para verlo.",
        );
        return;
      }

      hide("estado-carga");
      show("contenido");
      pintar(m);
      mensajeActual = m;
    })();

    document.getElementById("btn-papelera")?.addEventListener("click", async () => {
      if (!mensajeActual?.id) return;
      const ok = await confirmar("¿Mover este mensaje a papelera? Lo podés restaurar luego.");
      if (!ok) return;
      setStatus("Moviendo mensaje a papelera…", "info");
      const r = await moverMensajeAPapelera(mensajeActual.id);
      if (!r.ok) return setStatus(`No se pudo mover: ${r.error}`, "error");
      setStatus("Mensaje movido a papelera.", "ok");
      setTimeout(() => { window.location.href = "/area-reservada/mensajes"; }, 900);
    });

    document.getElementById("btn-borrar")?.addEventListener("click", async () => {
      if (!mensajeActual?.id) return;
      const ok = await confirmar("¿Eliminar definitivamente este mensaje? Esta acción no se puede deshacer.");
      if (!ok) return;
      setStatus("Eliminando mensaje definitivamente…", "info");
      const r = await eliminarMensajeDefinitivo(mensajeActual.id);
      if (!r.ok) return setStatus(`No se pudo eliminar: ${r.error}`, "error");
      setStatus("Mensaje eliminado definitivamente.", "ok");
      setTimeout(() => { window.location.href = "/area-reservada/mensajes"; }, 900);
    });
  </script>
</AdminLayout>
