---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Mi cuenta" active="cuenta">
  <header class="mb-8">
    <p class="title-eyebrow">Cuenta</p>
    <h1 class="font-display text-3xl text-parchment-50 mt-3">Mi cuenta</h1>
    <p class="text-parchment-300 mt-2 font-serif italic">
      Información de tu perfil y cambio de contraseña.
    </p>
  </header>

  {/* Datos del perfil */}
  <section class="card-altar p-7 lg:p-8 mb-6">
    <p class="title-eyebrow">Perfil</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4 mt-5 text-sm">
      <div>
        <div class="text-[10px] uppercase tracking-widest text-parchment-400">
          Email
        </div>
        <div class="text-parchment-100 mt-1" id="perfil-email">—</div>
      </div>
      <div>
        <div class="text-[10px] uppercase tracking-widest text-parchment-400">
          Rol
        </div>
        <div class="text-gold-300 mt-1 uppercase tracking-widest text-xs" id="perfil-rol">
          —
        </div>
      </div>
      <div>
        <div class="text-[10px] uppercase tracking-widest text-parchment-400">
          Nombre
        </div>
        <div class="text-parchment-100 mt-1" id="perfil-nombre">—</div>
      </div>
      <div>
        <div class="text-[10px] uppercase tracking-widest text-parchment-400">
          Cuenta creada
        </div>
        <div class="text-parchment-100 mt-1" id="perfil-creado">—</div>
      </div>
    </div>
  </section>

  {/* Cambiar password */}
  <section class="card-altar p-7 lg:p-8">
    <p class="title-eyebrow">Seguridad</p>
    <h2 class="font-display text-xl text-parchment-50 mt-3 mb-1">
      Cambiar contraseña
    </h2>
    <p class="text-xs text-parchment-400 font-serif italic mb-6">
      Necesitás haber iniciado sesión recientemente. Si te pide volver a
      loguearte, hacelo y volvé acá.
    </p>

    <form id="form-cambiar-password" class="space-y-5 max-w-md" novalidate>
      <div>
        <label
          for="password"
          class="block text-[11px] uppercase tracking-widest text-parchment-400 mb-2"
          >Nueva contraseña</label
        >
        <input
          id="password"
          name="password"
          type="password"
          required
          minlength="6"
          autocomplete="new-password"
          class="w-full bg-night-950/60 border border-gold-400/15 focus:border-gold-400/60 outline-none text-parchment-100 px-4 py-2.5 text-sm font-sans transition rounded-sm"
        />
        <p
          class="text-[10px] uppercase tracking-widest text-parchment-400 mt-2"
        >
          Mínimo 6 caracteres
        </p>
      </div>

      <div>
        <label
          for="password2"
          class="block text-[11px] uppercase tracking-widest text-parchment-400 mb-2"
          >Repetir contraseña</label
        >
        <input
          id="password2"
          name="password2"
          type="password"
          required
          minlength="6"
          autocomplete="new-password"
          class="w-full bg-night-950/60 border border-gold-400/15 focus:border-gold-400/60 outline-none text-parchment-100 px-4 py-2.5 text-sm font-sans transition rounded-sm"
        />
      </div>

      <div
        id="cuenta-status"
        class="hidden text-sm font-serif italic px-1"
        role="status"
        aria-live="polite"
      >
      </div>

      <button id="btn-guardar-pass" type="submit" class="btn-gold">
        Guardar contraseña
      </button>
    </form>
  </section>

  <script>
    import { obtenerPerfilActual, actualizarPassword } from "../../lib/auth";
    import { formatearFecha } from "../../lib/admin";

    function setText(id: string, v: string) {
      const el = document.getElementById(id);
      if (el) el.textContent = v;
    }

    function rolLabel(r: string): string {
      return (
        {
          super_admin: "Super admin",
          admin: "Admin",
          docente: "Docente",
          alumno: "Alumno",
        } as Record<string, string>
      )[r] ?? r;
    }

    (async () => {
      const perfil = await obtenerPerfilActual();
      if (!perfil) return;
      setText("perfil-email", perfil.email);
      setText("perfil-rol", rolLabel(perfil.rol));
      setText(
        "perfil-nombre",
        [perfil.nombre, perfil.apellido].filter(Boolean).join(" ") || "—",
      );
      setText("perfil-creado", formatearFecha(perfil.creado_en));
    })();

    const form = document.getElementById(
      "form-cambiar-password",
    ) as HTMLFormElement | null;
    const btn = document.getElementById(
      "btn-guardar-pass",
    ) as HTMLButtonElement | null;
    const status = document.getElementById("cuenta-status");

    function mostrarStatus(msg: string, tipo: "ok" | "error") {
      if (!status) return;
      status.textContent = msg;
      status.classList.remove("hidden", "text-gold-300", "text-wine-600");
      status.classList.add(
        tipo === "ok" ? "text-gold-300" : "text-wine-600",
      );
    }

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!btn) return;

      const fd = new FormData(form);
      const p1 = String(fd.get("password") ?? "");
      const p2 = String(fd.get("password2") ?? "");

      if (p1.length < 6) {
        mostrarStatus(
          "La contraseña debe tener al menos 6 caracteres.",
          "error",
        );
        return;
      }
      if (p1 !== p2) {
        mostrarStatus("Las contraseñas no coinciden.", "error");
        return;
      }

      btn.disabled = true;
      btn.textContent = "Guardando…";
      if (status) status.classList.add("hidden");

      const r = await actualizarPassword(p1);

      if (r.ok) {
        mostrarStatus("Contraseña actualizada correctamente.", "ok");
        btn.textContent = "Guardado ✓";
        form.reset();
        setTimeout(() => {
          if (btn) {
            btn.disabled = false;
            btn.textContent = "Guardar contraseña";
          }
        }, 3000);
        return;
      }

      const errores: Record<string, string> = {
        password_corta: "La contraseña debe tener al menos 6 caracteres.",
        password_iguales:
          "La nueva contraseña tiene que ser distinta a la anterior.",
        no_autenticado:
          "Tu sesión expiró. Cerrá sesión, volvé a entrar y probá de nuevo.",
        red: "No pude conectar con el servidor.",
        config: "Configuración faltante.",
      };
      mostrarStatus(errores[r.error ?? ""] ?? "Algo salió mal.", "error");
      btn.disabled = false;
      btn.textContent = "Guardar contraseña";
    });
  </script>
</AdminLayout>
