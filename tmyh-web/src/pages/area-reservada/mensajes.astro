---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Mensajes" active="mensajes">
  <header class="mb-8">
    <div class="flex items-end justify-between gap-4 flex-wrap">
      <div>
        <p class="title-eyebrow">Bandeja</p>
        <h1 class="font-display text-3xl text-parchment-50 mt-3">Mensajes recibidos</h1>
        <p class="text-parchment-300 mt-2 font-serif italic">
          Los mensajes que estás viendo también te llegan a tu casilla de email.
          Respondelos desde ahí, acá no se almacena la conversación, así podés llevar el ida y vuelta de la charla con el alumno.
        </p>
      </div>
      <a
        href="/area-reservada/mensajes/papelera"
        class="inline-flex items-center gap-2 px-4 py-2.5 rounded-sm border border-wine-500/40 bg-night-950/50 text-[11px] font-sans uppercase tracking-[0.14em] text-parchment-200 hover:text-parchment-50 hover:border-wine-400/55 hover:bg-wine-900/20 transition shrink-0"
      >
        <span class="text-sm opacity-90" aria-hidden="true">🗑</span>
        Papelera
      </a>
    </div>
  </header>

  <div class="flex items-center gap-3 mb-6 flex-wrap">
    <span
      id="contador"
      class="text-[10px] uppercase tracking-widest text-parchment-400 px-2 py-1 border border-gold-400/20 rounded-sm bg-night-950/50"
    >
      —
    </span>

    <div class="flex-1"></div>

    <input
      id="buscador"
      type="search"
      placeholder="Buscar por nombre, email, curso…"
      class="bg-night-950/60 border border-gold-400/15 focus:border-gold-400/60 outline-none text-parchment-100 px-3 py-1.5 text-xs font-sans transition rounded-sm w-full sm:w-72"
    />
  </div>

  <section id="lista-mensajes" class="card-altar divide-y divide-gold-400/10">
    <div
      class="py-12 text-center text-parchment-400 text-sm font-serif italic"
    >
      Cargando mensajes…
    </div>
  </section>

  <style>
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>

  <script>
    import {
      listarMensajes,
      formatearFecha,
      nombreCompleto,
      type MensajeContacto,
    } from "../../lib/admin";

    const lista = document.getElementById("lista-mensajes");
    const buscador = document.getElementById("buscador") as HTMLInputElement | null;
    const contador = document.getElementById("contador");
    let cache: MensajeContacto[] = [];

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function pintar(mensajes: MensajeContacto[]) {
      if (!lista) return;
      if (contador) {
        contador.textContent =
          mensajes.length === 1
            ? "1 mensaje"
            : `${mensajes.length} mensajes`;
      }

      if (mensajes.length === 0) {
        lista.innerHTML = `
          <div class="py-16 text-center">
            <div class="text-2xl text-gold-400 mb-3 opacity-50">☉</div>
            <p class="text-parchment-300 font-serif italic">No hay mensajes que coincidan.</p>
          </div>
        `;
        return;
      }

      lista.innerHTML = mensajes
        .map(
          (m) => `
        <a
          href="/area-reservada/mensaje?id=${m.id}"
          class="block px-6 py-5 hover:bg-gold-400/5 transition"
        >
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 flex-wrap">
                <div class="font-display text-parchment-50">${escapeHtml(nombreCompleto(m))}</div>
                ${
                  m.newsletter_optin
                    ? '<span class="text-[9px] uppercase tracking-widest text-gold-300 px-1.5 py-0.5 border border-gold-400/30 rounded-sm bg-gold-400/5">Newsletter</span>'
                    : ""
                }
              </div>
              <div class="text-xs text-parchment-400 mt-0.5">${escapeHtml(m.email)}</div>
              ${m.curso_interes ? `<div class="text-xs text-gold-300 mt-1.5">${escapeHtml(m.curso_interes)}</div>` : ""}
              <p class="text-sm text-parchment-300 mt-2 font-serif line-clamp-2 max-w-2xl">
                ${escapeHtml(m.mensaje)}
              </p>
            </div>
            <div class="text-[11px] text-parchment-400 uppercase tracking-widest whitespace-nowrap text-right">
              ${escapeHtml(formatearFecha(m.creado_en))}
            </div>
          </div>
        </a>
      `,
        )
        .join("");
    }

    function aplicarBusqueda(q: string) {
      const norm = q.trim().toLowerCase();
      if (!norm) {
        pintar(cache);
        return;
      }
      const filtrados = cache.filter((m) => {
        const blob = `${m.nombre} ${m.apellido ?? ""} ${m.email} ${m.curso_interes ?? ""} ${m.mensaje}`.toLowerCase();
        return blob.includes(norm);
      });
      pintar(filtrados);
    }

    (async () => {
      cache = await listarMensajes(500);
      aplicarBusqueda(buscador?.value ?? "");
    })();

    buscador?.addEventListener("input", () =>
      aplicarBusqueda(buscador.value),
    );
  </script>
</AdminLayout>
