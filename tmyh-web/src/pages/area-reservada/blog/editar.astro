---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import EditorBlog from "../../../components/EditorBlog.astro";
---

<AdminLayout title="Editar post" active="blog">
  <a
    href="/area-reservada/blog"
    class="text-xs uppercase tracking-widest text-parchment-300 hover:text-gold-300 transition inline-flex items-center gap-2 mb-6"
  >
    ← Volver al blog
  </a>

  <div id="estado-carga" class="card-altar p-12 text-center">
    <div class="text-2xl text-gold-400 animate-soft-pulse">☉</div>
    <p class="mt-3 text-sm text-parchment-300 font-serif italic">Cargando post…</p>
  </div>

  <div id="estado-error" class="card-altar p-12 text-center hidden">
    <div class="text-2xl text-wine-600 mb-3">⚠</div>
    <p class="font-display text-lg text-parchment-50">Post no encontrado</p>
    <a href="/area-reservada/blog" class="btn-ghost mt-6 inline-flex">Volver</a>
  </div>

  <div id="contenido" class="hidden space-y-6">
    <div id="estado-guardando" class="hidden fixed top-4 right-4 z-50 bg-gold-400 text-night-950 text-xs font-sans uppercase tracking-widest px-4 py-2 rounded-sm shadow-lg">
      Guardando…
    </div>

    <!-- Header con estado -->
    <div class="flex items-center justify-between gap-4 flex-wrap">
      <div>
        <p class="title-eyebrow">Editando post</p>
        <h1 id="header-titulo" class="font-display text-2xl text-parchment-50 mt-2"></h1>
      </div>
      <div class="flex items-center gap-3">
        <span id="badge-estado" class="text-[10px] uppercase tracking-widest px-2 py-1 rounded-sm border"></span>
        <a id="link-ver-post" href="#" target="_blank" rel="noopener"
           class="text-xs uppercase tracking-widest text-parchment-300 hover:text-gold-300 transition hidden">
          Ver en el sitio →
        </a>
      </div>
    </div>

    <form id="form-post" class="space-y-6" novalidate>
      <!-- Título -->
      <div>
        <label for="titulo" class="block text-[11px] uppercase tracking-widest text-parchment-400 mb-2">Título</label>
        <input
          id="titulo" name="titulo" type="text" required
          class="w-full bg-night-950/60 border border-gold-400/15 focus:border-gold-400/60 outline-none text-parchment-50 px-4 py-3 font-display text-2xl transition rounded-sm"
        />
      </div>

      <!-- Slug + Extracto -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <label for="slug" class="block text-[11px] uppercase tracking-widest text-parchment-400 mb-2">Slug (URL)</label>
          <div class="flex items-center gap-0 bg-night-950/60 border border-gold-400/15 focus-within:border-gold-400/60 rounded-sm transition">
            <span class="px-3 py-2.5 text-parchment-500 text-sm font-sans border-r border-gold-400/15 select-none">/blog/</span>
            <input
              id="slug" name="slug" type="text" required
              class="flex-1 bg-transparent outline-none text-parchment-100 px-3 py-2.5 text-sm font-mono"
            />
          </div>
        </div>
        <div>
          <label for="extracto" class="block text-[11px] uppercase tracking-widest text-parchment-400 mb-2">Extracto</label>
          <input
            id="extracto" name="extracto" type="text" maxlength="220"
            class="w-full bg-night-950/60 border border-gold-400/15 focus:border-gold-400/60 outline-none text-parchment-100 px-4 py-2.5 text-sm font-serif transition rounded-sm"
          />
        </div>
      </div>

      <!-- Editor -->
      <div>
        <label class="block text-[11px] uppercase tracking-widest text-parchment-400 mb-2">Contenido</label>
        <div class="border border-gold-400/15 rounded-sm overflow-hidden">
          <EditorBlog />
        </div>
      </div>

      <!-- Etiquetas -->
      <div>
        <label for="etiquetas" class="block text-[11px] uppercase tracking-widest text-parchment-400 mb-2">Etiquetas (separadas por comas)</label>
        <input
          id="etiquetas" name="etiquetas" type="text"
          class="w-full bg-night-950/60 border border-gold-400/15 focus:border-gold-400/60 outline-none text-parchment-100 px-4 py-2.5 text-sm font-serif transition rounded-sm"
        />
      </div>

      <!-- Status -->
      <div id="status-post" class="hidden text-sm font-serif italic" role="status" aria-live="polite"></div>

      <!-- Acciones -->
      <div class="space-y-3 pt-2 border-t border-gold-400/10">

        <!-- Fila principal de acciones -->
        <div class="flex flex-wrap gap-3">
          <button id="btn-guardar" type="button" class="btn-ghost">Guardar borrador</button>
          <button id="btn-publicar" type="button" class="btn-gold hidden">Publicar</button>
          <button id="btn-publicar-revision" type="button" class="btn-gold hidden">Publicar revisión</button>
          <button id="btn-despublicar" type="button" class="btn-ghost hidden">Volver a borrador</button>
          <div class="flex-1"></div>
          <button id="btn-archivar" type="button"
            class="text-[11px] uppercase tracking-widest text-parchment-400 hover:text-parchment-100 transition px-3 py-2">
            Archivar
          </button>
          <button id="btn-papelera" type="button"
            class="text-[11px] uppercase tracking-widest text-parchment-500 hover:text-wine-500 transition px-3 py-2">
            🗑 Papelera
          </button>
        </div>

        <!-- Aviso de revisión pendiente (solo visible cuando hay borrador sobre un post publicado) -->
        <div id="aviso-borrador" class="hidden bg-gold-400/8 border border-gold-400/20 rounded-sm px-4 py-3 flex items-center justify-between gap-4 flex-wrap">
          <p class="text-xs font-sans text-parchment-200">
            <span class="text-gold-300 font-medium">Revisión pendiente</span> —
            hay cambios guardados sin publicar. El sitio en vivo sigue mostrando la versión anterior.
          </p>
          <button id="btn-descartar-borrador" type="button"
            class="text-[11px] uppercase tracking-widest text-parchment-400 hover:text-wine-400 transition shrink-0">
            Descartar
          </button>
        </div>

      </div>
    </form>
  </div>

  <script>
    import {
      obtenerPost,
      guardarPost,
      guardarBorrador,
      publicarRevision,
      descartarBorrador,
      archivarPost,
      moverAPapelera,
      type PostBlog,
    } from "../../../lib/admin";

    // Toast de notificación (reemplaza window.alert)
    function notificar(msg: string, tipo: "ok" | "error" | "info" = "info") {
      const existing = document.getElementById("toast-notif");
      if (existing) existing.remove();
      const toast = document.createElement("div");
      toast.id = "toast-notif";
      const color = tipo === "ok" ? "bg-gold-400 text-night-950"
                  : tipo === "error" ? "bg-wine-700 text-parchment-50"
                  : "bg-night-900 border border-gold-400/30 text-parchment-100";
      toast.className = `fixed bottom-6 right-6 z-[999] px-5 py-3 rounded-sm shadow-xl font-sans text-sm max-w-sm ${color} transition-all`;
      toast.textContent = msg;
      document.body.appendChild(toast);
      setTimeout(() => { toast.classList.add("opacity-0"); setTimeout(() => toast.remove(), 400); }, 3500);
    }

    // Confirm personalizado (reemplaza window.confirm)
    function confirmar(msg: string): Promise<boolean> {
      return new Promise((resolve) => {
        const overlay = document.createElement("div");
        overlay.className = "fixed inset-0 z-[998] flex items-center justify-center bg-night-950/80 backdrop-blur-sm";
        overlay.innerHTML = `
          <div class="card-altar p-8 max-w-md mx-4 space-y-5">
            <p class="font-serif text-base text-parchment-100 leading-relaxed">${msg}</p>
            <div class="flex gap-3 justify-end">
              <button id="conf-cancel" class="btn-ghost text-sm">Cancelar</button>
              <button id="conf-ok" class="btn-gold text-sm">Confirmar</button>
            </div>
          </div>`;
        document.body.appendChild(overlay);
        overlay.querySelector("#conf-ok")?.addEventListener("click", () => { overlay.remove(); resolve(true); });
        overlay.querySelector("#conf-cancel")?.addEventListener("click", () => { overlay.remove(); resolve(false); });
        overlay.addEventListener("click", (e) => { if (e.target === overlay) { overlay.remove(); resolve(false); } });
      });
    }

    let postId: string | null = null;
    let contenidoJson: unknown = null;
    let contenidoHtml = "";

    // Escuchar cambios del editor Tiptap
    document.getElementById("editor-blog-root")?.addEventListener(
      "editor:change",
      (e: Event) => {
        const { json, html } = (e as CustomEvent).detail;
        contenidoJson = json;
        contenidoHtml = html;
      },
    );

    function setText(id: string, value: string) {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    }
    function show(id: string) { document.getElementById(id)?.classList.remove("hidden"); }
    function hide(id: string) { document.getElementById(id)?.classList.add("hidden"); }
    function setVal(id: string, value: string) {
      const el = document.getElementById(id) as HTMLInputElement | null;
      if (el) el.value = value;
    }

    function setStatus(msg: string, tipo: "ok" | "error" | "info") {
      const el = document.getElementById("status-post");
      if (!el) return;
      el.textContent = msg;
      el.classList.remove("hidden", "text-gold-300", "text-wine-600", "text-parchment-300");
      el.classList.add(
        tipo === "ok" ? "text-gold-300"
        : tipo === "error" ? "text-wine-600"
        : "text-parchment-300",
      );
    }

    function pintarEstado(estado: PostBlog["estado"]) {
      const badge = document.getElementById("badge-estado");
      const btnGuardar = document.getElementById("btn-guardar");
      if (!badge) return;
      badge.className = "text-[10px] uppercase tracking-widest px-2 py-1 rounded-sm border";
      if (estado === "publicado") {
        badge.textContent = "Publicado";
        badge.classList.add("text-gold-300", "border-gold-400/40", "bg-gold-400/5");
        // Publicado: "Guardar borrador" guarda sin publicar, "Volver a borrador" lo baja
        if (btnGuardar) btnGuardar.textContent = "Guardar borrador";
        show("btn-despublicar"); hide("btn-publicar");
        show("link-ver-post");
      } else if (estado === "borrador") {
        badge.textContent = "Borrador";
        badge.classList.add("text-parchment-400", "border-parchment-400/30");
        // Borrador: "Guardar cambios" guarda y "Publicar" lo pone live
        if (btnGuardar) btnGuardar.textContent = "Guardar cambios";
        show("btn-publicar"); hide("btn-despublicar");
        hide("link-ver-post");
      } else {
        badge.textContent = "Archivado";
        badge.classList.add("text-parchment-600", "border-parchment-600/20", "opacity-60");
        if (btnGuardar) btnGuardar.textContent = "Guardar cambios";
        show("btn-publicar"); hide("btn-despublicar");
        hide("link-ver-post");
      }
    }

    let esPublicado = false;

    function recopilarCampos() {
      return {
        titulo:   (document.getElementById("titulo") as HTMLInputElement)?.value.trim() ?? "",
        slug:     (document.getElementById("slug") as HTMLInputElement)?.value.trim() ?? "",
        extracto: (document.getElementById("extracto") as HTMLInputElement)?.value.trim() || null,
        etiquetas: ((document.getElementById("etiquetas") as HTMLInputElement)?.value ?? "")
          .split(",").map((e) => e.trim()).filter(Boolean),
        contenido_json: contenidoJson,
        contenido_html: contenidoHtml,
      };
    }

    function mostrarAvisoBorrador(visible: boolean) {
      const aviso = document.getElementById("aviso-borrador");
      const btnRevision = document.getElementById("btn-publicar-revision");
      if (visible) {
        aviso?.classList.remove("hidden");
        btnRevision?.classList.remove("hidden");
      } else {
        aviso?.classList.add("hidden");
        btnRevision?.classList.add("hidden");
      }
    }

    async function accionGuardar() {
      const campos = recopilarCampos();
      if (!campos.titulo) { setStatus("El título es obligatorio.", "error"); return; }
      if (!campos.slug)   { setStatus("El slug es obligatorio.", "error"); return; }
      const guardando = document.getElementById("estado-guardando");
      guardando?.classList.remove("hidden");
      setStatus("Guardando…", "info");

      let r: { ok: boolean; error?: string };
      if (esPublicado) {
        // Post publicado → guardar como revisión pendiente (no toca el live)
        r = await guardarBorrador(postId!, campos);
      } else {
        // Post en borrador → guardar directamente
        r = await guardarPost({ id: postId!, ...campos, estado: "borrador" } as any);
      }
      guardando?.classList.add("hidden");
      if (!r.ok) { setStatus(`Error al guardar: ${r.error}`, "error"); return; }

      if (esPublicado) {
        setStatus("Borrador guardado. El sitio en vivo no cambió.", "ok");
        mostrarAvisoBorrador(true);
      } else {
        setStatus("Cambios guardados.", "ok");
      }
    }

    async function accionPublicar() {
      const campos = recopilarCampos();
      if (!campos.titulo) { setStatus("El título es obligatorio.", "error"); return; }
      if (!campos.slug)   { setStatus("El slug es obligatorio.", "error"); return; }
      const guardando = document.getElementById("estado-guardando");
      guardando?.classList.remove("hidden");
      setStatus("Publicando…", "info");

      const r = await publicarRevision(postId!, campos);
      guardando?.classList.add("hidden");
      if (!r.ok) { setStatus(`Error al publicar: ${r.error}`, "error"); return; }

      esPublicado = true;
      pintarEstado("publicado");
      setText("header-titulo", campos.titulo);
      const linkVer = document.getElementById("link-ver-post") as HTMLAnchorElement | null;
      if (linkVer) linkVer.href = `/blog/post?slug=${campos.slug}`;
      mostrarAvisoBorrador(false);
      setStatus("Publicado. El sitio se actualizará en ~10 minutos.", "ok");
    }

    (async () => {
      const params = new URLSearchParams(window.location.search);
      postId = params.get("id");

      if (!postId) {
        hide("estado-carga"); show("estado-error");
        return;
      }

      const post = await obtenerPost(postId);
      if (!post) {
        hide("estado-carga"); show("estado-error");
        return;
      }

      // Cargar el contenido en el editor DESPUÉS de obtener el post.
      // Usamos requestAnimationFrame para garantizar que EditorBlog.astro
      // ya terminó de inicializar su listener antes de disparar el evento.
      const editorRoot = document.getElementById("editor-blog-root");
      if (editorRoot && (post.contenido_json || post.contenido_html)) {
        const dispatchContent = () => {
          if (post.contenido_json) {
            editorRoot.dispatchEvent(new CustomEvent("editor:setContent", {
              detail: { json: post.contenido_json },
            }));
          } else if (post.contenido_html) {
            editorRoot.dispatchEvent(new CustomEvent("editor:setContent", {
              detail: { html: post.contenido_html },
            }));
          }
        };
        dispatchContent();
        requestAnimationFrame(dispatchContent);
      }

      // Llenar los campos
      setVal("titulo", post.titulo);
      setVal("slug", post.slug);
      setVal("extracto", post.extracto ?? "");
      setVal("etiquetas", post.etiquetas?.join(", ") ?? "");
      setText("header-titulo", post.titulo);

      const linkVer = document.getElementById("link-ver-post") as HTMLAnchorElement | null;
      if (linkVer) linkVer.href = `/blog/post?slug=${post.slug}`;

      esPublicado = post.estado === "publicado";
      pintarEstado(post.estado);

      // Cargar en el editor el borrador pendiente si existe, o el contenido publicado
      contenidoJson = post.borrador_json ?? post.contenido_json;
      contenidoHtml = post.borrador_html ?? post.contenido_html ?? "";

      // Si hay borrador pendiente, cargar esos datos en los campos también
      if (post.borrador_modificado_en) {
        setVal("titulo", post.borrador_titulo ?? post.titulo);
        setVal("slug", post.borrador_slug ?? post.slug);
        setVal("extracto", post.borrador_extracto ?? post.extracto ?? "");
        setVal("etiquetas", (post.borrador_etiquetas ?? post.etiquetas)?.join(", ") ?? "");
        mostrarAvisoBorrador(true);
      } else {
        setVal("titulo", post.titulo);
        setVal("slug", post.slug);
        setVal("extracto", post.extracto ?? "");
        setVal("etiquetas", post.etiquetas?.join(", ") ?? "");
      }

      setText("header-titulo", post.titulo);

      hide("estado-carga");
      show("contenido");

      // Botones
      document.getElementById("btn-guardar")?.addEventListener("click", accionGuardar);
      document.getElementById("btn-publicar")?.addEventListener("click", accionPublicar);
      document.getElementById("btn-publicar-revision")?.addEventListener("click", accionPublicar);
      document.getElementById("btn-despublicar")?.addEventListener("click", async () => {
        const r = await guardarPost({ id: postId!, estado: "borrador" } as any);
        if (r.ok) { esPublicado = false; pintarEstado("borrador"); setStatus("Vuelto a borrador.", "ok"); }
        else setStatus(`Error: ${r.error}`, "error");
      });
      document.getElementById("btn-descartar-borrador")?.addEventListener("click", async () => {
        if (!await confirmar("¿Descartar los cambios sin publicar? Se restaurará la última versión publicada.")) return;
        const r = await descartarBorrador(postId!);
        if (r.ok) {
          mostrarAvisoBorrador(false);
          setStatus("Borrador descartado. Recargando…", "ok");
          setTimeout(() => window.location.reload(), 1200);
        } else setStatus(`Error: ${r.error}`, "error");
      });
      document.getElementById("btn-archivar")?.addEventListener("click", async () => {
        if (!await confirmar("¿Archivar este post? Dejará de ser visible en el sitio, pero lo podés recuperar desde el filtro 'Archivados'.")) return;
        const r = await archivarPost(postId!);
        if (r.ok) { esPublicado = false; pintarEstado("archivado"); setStatus("Post archivado.", "ok"); }
        else setStatus(`Error: ${r.error}`, "error");
      });
      document.getElementById("btn-papelera")?.addEventListener("click", async () => {
        if (!await confirmar("¿Mover a la papelera? Quedará ahí 30 días. Podés restaurarlo o borrarlo definitivamente desde 'Papelera'.")) return;
        const r = await moverAPapelera(postId!);
        if (r.ok) { setStatus("Post movido a la papelera.", "ok"); setTimeout(() => { window.location.href = "/area-reservada/blog"; }, 1200); }
        else setStatus(`Error: ${r.error}`, "error");
      });
    })();
  </script>
</AdminLayout>
