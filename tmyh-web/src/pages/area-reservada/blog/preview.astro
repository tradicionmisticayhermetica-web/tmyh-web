---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Ornament from "../../../components/Ornament.astro";
---

<BaseLayout
  title="Vista previa"
  description="Borrador local — no publicado"
  noindex={true}
>
  <article>
    <div id="estado-vacio" class="py-24 text-center hidden">
      <p class="font-display text-xl text-parchment-200 mb-4">No hay vista previa</p>
      <p class="text-sm text-parchment-400 mb-8 max-w-md mx-auto">
        Abrila desde el editor del blog con el botón «Vista previa». Los datos se guardan en tu navegador al usar ese botón.
      </p>
      <a href="/area-reservada/blog" class="btn-gold">Volver al panel del blog</a>
    </div>

    <div id="contenido" class="hidden">
      <section class="relative py-16 md:py-24 overflow-hidden">
        <div class="stars-bg"></div>
        <div class="container-prose relative z-10 max-w-3xl">
          <p
            class="inline-flex items-center gap-2 text-[10px] tracking-[0.2em] uppercase text-gold-400 border border-gold-400/30 px-3 py-1.5 rounded-sm mb-8"
          >
            Vista previa · no publicado
          </p>

          <div id="hero-meta" class="flex items-center gap-3 mb-6 text-xs tracking-[0.2em] uppercase"></div>

          <h1 id="post-titulo" class="text-4xl md:text-5xl font-display text-balance text-parchment-50"></h1>
          <p id="post-extracto" class="hidden mt-5 text-lg font-serif text-parchment-300 leading-relaxed"></p>
          <p class="mt-6 text-xs tracking-[0.2em] uppercase text-parchment-400">Por Emanuel Mari</p>

          <p class="mt-10">
            <a
              href="/area-reservada/blog"
              class="text-xs tracking-[0.2em] uppercase text-parchment-400 hover:text-gold-300 transition"
            >
              ← Volver al panel
            </a>
          </p>
        </div>
      </section>

      <Ornament symbol="✦" />

      <section class="py-12">
        <div class="container-prose max-w-3xl">
          <div
            id="post-cuerpo"
            class="blog-content text-lg font-serif leading-[1.8] text-parchment-100"
          ></div>
        </div>
      </section>

      <Ornament symbol="☉" />

      <section class="pb-12">
        <div class="container-prose max-w-3xl">
          <div id="post-etiquetas" class="flex flex-wrap gap-2"></div>
        </div>
      </section>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .blog-content p { margin-bottom: 1.5rem; }
  .blog-content h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--color-parchment-50);
    margin: 3rem 0 1.25rem 0;
    line-height: 1.25;
  }
  .blog-content h3 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--color-gold-300);
    margin: 2rem 0 0.75rem 0;
  }
  .blog-content blockquote {
    border-left: 2px solid var(--color-gold-500);
    padding: 0.5rem 0 0.5rem 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--color-parchment-200);
  }
  .blog-content hr {
    border: none;
    text-align: center;
    margin: 2.5rem 0;
    color: var(--color-gold-400);
    opacity: 0.6;
  }
  .blog-content hr::after { content: "☉"; font-size: 1.2rem; }
  .blog-content ul { list-style: none; padding-left: 1.5rem; margin-bottom: 1.5rem; }
  .blog-content ul li::before {
    content: "◆";
    color: var(--color-gold-500);
    font-size: 0.55rem;
    margin-right: 0.6rem;
    vertical-align: middle;
  }
  .blog-content ol { padding-left: 1.5rem; margin-bottom: 1.5rem; }
  .blog-content ol li { color: var(--color-parchment-100); margin-bottom: 0.4rem; }
  .blog-content a {
    color: var(--color-gold-300);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .blog-content strong { color: var(--color-parchment-50); font-weight: 600; }
  .blog-content em { color: var(--color-parchment-200); }
  .blog-content img {
    max-width: 100%;
    border-radius: 2px;
    margin: 2rem auto;
    display: block;
  }
  .blog-content .blog-content-video,
  .blog-content video.blog-content-video {
    width: 100%;
    max-width: 100%;
    border-radius: 2px;
    margin: 2rem auto;
    display: block;
    background: rgb(0 0 0 / 0.25);
  }
  .blog-content .blog-pdf-block {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
    margin: 2rem 0;
    padding: 1rem 1.25rem;
    border: 1px solid rgb(212 175 55 / 0.22);
    border-radius: 2px;
    background: rgb(230 196 100 / 0.05);
  }
  .blog-content .blog-pdf-badge {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-parchment-500);
  }
  .blog-content a.blog-pdf-download {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gold-400);
    text-decoration: none;
    border-bottom: 1px solid rgb(212 175 55 / 0.3);
    padding-bottom: 1px;
  }
  .blog-content a.blog-pdf-download:hover {
    color: var(--color-gold-300);
    border-color: rgb(212 175 55 / 0.55);
  }
  .blog-content table.blog-layout-table {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    border: none;
    table-layout: fixed;
  }
  .blog-content table.blog-layout-table td,
  .blog-content table.blog-layout-table th {
    border: none;
    vertical-align: top;
    padding: 0.5rem 1rem;
    width: 50%;
  }
  @media (max-width: 640px) {
    .blog-content table.blog-layout-table,
    .blog-content table.blog-layout-table tbody,
    .blog-content table.blog-layout-table tr {
      display: block;
      width: 100%;
    }
    .blog-content table.blog-layout-table td,
    .blog-content table.blog-layout-table th {
      display: block;
      width: 100%;
      padding: 0.75rem 0;
    }
  }
  .blog-content iframe {
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: 2px;
    margin: 2rem 0;
    display: block;
  }
</style>

<script>
  import {
    BLOG_PREVIEW_STORAGE_KEY,
    type BlogPreviewPayload,
  } from "../../../lib/blog-preview";

  function show(id: string) {
    document.getElementById(id)?.classList.remove("hidden");
  }
  function hide(id: string) {
    document.getElementById(id)?.classList.add("hidden");
  }

  (function init() {
    const raw = localStorage.getItem(BLOG_PREVIEW_STORAGE_KEY);
    if (!raw) {
      hide("contenido");
      show("estado-vacio");
      return;
    }

    let data: BlogPreviewPayload;
    try {
      data = JSON.parse(raw) as BlogPreviewPayload;
    } catch {
      hide("contenido");
      show("estado-vacio");
      return;
    }

    document.title = `${data.titulo} (vista previa) · Tradición Mística y Hermética`;

    const tituloEl = document.getElementById("post-titulo");
    if (tituloEl) tituloEl.textContent = data.titulo || "Sin título";

    if (data.extracto) {
      const ex = document.getElementById("post-extracto");
      if (ex) {
        ex.textContent = data.extracto;
        ex.classList.remove("hidden");
      }
    }

    const heroMeta = document.getElementById("hero-meta");
    if (heroMeta && data.etiquetas?.length) {
      const primera = data.etiquetas[0];
      heroMeta.innerHTML = `<span class="text-[color:var(--color-gold-400)]">${primera}</span>`;
    }

    const cuerpo = document.getElementById("post-cuerpo");
    if (cuerpo) {
      cuerpo.innerHTML =
        data.contenido_html?.trim()
          ? data.contenido_html
          : "<p class=\"text-parchment-400 italic\">Sin contenido en el editor.</p>";
    }

    const etiquetasEl = document.getElementById("post-etiquetas");
    if (etiquetasEl && data.etiquetas?.length) {
      etiquetasEl.innerHTML = data.etiquetas
        .map(
          (e) =>
            `<span class="text-[10px] uppercase tracking-widest text-parchment-400 px-2 py-1 border border-gold-400/15 rounded-sm">${e}</span>`,
        )
        .join("");
    }

    show("contenido");
  })();
</script>
