    function confirmar(msg: string): Promise<boolean> {
      return new Promise((resolve) => {
        const overlay = document.createElement("div");
        overlay.className = "fixed inset-0 z-[998] flex items-center justify-center bg-night-950/80 backdrop-blur-sm";
        overlay.innerHTML = `
          <div class="card-altar p-8 max-w-md mx-4 space-y-5">
            <p class="font-serif text-base text-parchment-100 leading-relaxed">${msg}</p>
            <div class="flex gap-3 justify-end">
              <button id="conf-cancel" class="btn-ghost text-sm">Cancelar</button>
              <button id="conf-ok" class="btn-gold text-sm">Confirmar</button>
            </div>
          </div>`;
        document.body.appendChild(overlay);
        overlay.querySelector("#conf-ok")?.addEventListener("click", () => { overlay.remove(); resolve(true); });
        overlay.querySelector("#conf-cancel")?.addEventListener("click", () => { overlay.remove(); resolve(false); });
        overlay.addEventListener("click", (e) => { if (e.target === overlay) { overlay.remove(); resolve(false); } });
      });
    }

    function avisar(msg: string): Promise<void> {
      return new Promise((resolve) => {
        const overlay = document.createElement("div");
        overlay.className = "fixed inset-0 z-[998] flex items-center justify-center bg-night-950/80 backdrop-blur-sm";
        overlay.innerHTML = `
          <div class="card-altar p-8 max-w-md mx-4 space-y-5">
            <p class="font-serif text-base text-parchment-100 leading-relaxed">${msg}</p>
            <div class="flex justify-end">
              <button id="alert-ok" class="btn-gold text-sm">Entendido</button>
            </div>
          </div>`;
        document.body.appendChild(overlay);
        const close = () => {
          overlay.remove();
          resolve();
        };
        overlay.querySelector("#alert-ok")?.addEventListener("click", close);
        overlay.addEventListener("click", (e) => { if (e.target === overlay) close(); });
      });
    }

    function setStatus(msg: string, tipo: "ok" | "error" | "info") {
      if (!$status) return;
      $status.textContent = msg;
      $status.classList.remove("hidden", "text-gold-300", "text-wine-500", "text-parchment-300");
      $status.classList.add(tipo === "ok" ? "text-gold-300" : tipo === "error" ? "text-wine-500" : "text-parchment-300");
    }

    function ensureLoaderFallback() {
      if (loaderFallback) return loaderFallback;
      const wrap = document.createElement("div");
      wrap.className = "hidden fixed inset-0 z-[1400] items-center justify-center bg-night-950/78 backdrop-blur-[2px]";
      wrap.innerHTML = `
        <div class="card-altar px-8 py-7 text-center min-w-[300px]">
          <div class="loader-triad" aria-hidden="true">
            <span class="loader-sym m">☿</span>
            <span class="loader-sym a">🜍</span>
            <span class="loader-sym s">🜔</span>
          </div>
          <p class="loader-msg mt-5 text-xs tracking-widest uppercase text-parchment-200">Procesando…</p>
        </div>`;
      document.body.appendChild(wrap);
      loaderFallback = wrap;
      return wrap;
    }

    function showLoader(msg = "Procesando…") {
      if (loaderWatchdog) clearTimeout(loaderWatchdog);
      loaderWatchdog = setTimeout(() => {
        hideLoader();
        setStatus(
          "La operación tardó demasiado. Verificá conexión/Supabase y reintentá.",
          "error",
        );
      }, 15000);
      const uiLoader = (window as any).__tmyhLoader;
      if (uiLoader?.show) {
        uiLoader.show(msg);
        return;
      }
      const wrap = ensureLoaderFallback();
      const msgEl = wrap.querySelector(".loader-msg");
      if (msgEl) msgEl.textContent = msg;
      wrap.classList.remove("hidden");
      wrap.classList.add("flex");
    }

    function hideLoader() {
      if (loaderWatchdog) {
        clearTimeout(loaderWatchdog);
        loaderWatchdog = null;
      }
      const uiLoader = (window as any).__tmyhLoader;
      if (uiLoader?.hide) {
        uiLoader.hide();
        return;
      }
      if (!loaderFallback) return;
      loaderFallback.classList.add("hidden");
      loaderFallback.classList.remove("flex");
    }

    async function withTimeout<T>(
      promise: Promise<T>,
      ms: number,
      label: string,
    ): Promise<T> {
      let timer: ReturnType<typeof setTimeout> | null = null;
      try {
        return await Promise.race<T>([
          promise,
          new Promise<T>((_, reject) => {
            timer = setTimeout(() => {
              reject(new Error(`timeout:${label}`));
            }, ms);
          }),
        ]);
      } finally {
        if (timer) clearTimeout(timer);
      }
    }

    function slugify(s: string): string {
      return s.toLowerCase()
        .normalize("NFD").replace(/[\u0300-\u036f]/g, "")
        .replace(/[^a-z0-9\s-]/g, "")
        .trim().replace(/\s+/g, "-");
    }

    function agregarModulo(titulo = "", items: string[] = [""]) {
      if (!$temario) return;
      const idx = Date.now() + Math.floor(Math.random() * 1000);
      const mod = document.createElement("div");
      mod.className = "tema-modulo";
      mod.innerHTML = `
        <div class="flex items-center justify-between gap-3 mb-3">
          <input data-role="titulo-modulo" type="text" class="input flex-1 min-w-0" placeholder="Título módulo (opcional)" value="${titulo.replace(/"/g, "&quot;")}" />
          <button type="button" class="btn-ghost text-xs h-10 px-5 shrink-0" data-remove-modulo="${idx}">Eliminar módulo</button>
        </div>
        <div data-role="items-wrap"></div>
        <button type="button" class="btn-ghost text-xs h-10 px-5 mt-3" data-add-item="${idx}">+ Agregar tema</button>
      `;
      $temario.appendChild(mod);

      const wrap = mod.querySelector('[data-role="items-wrap"]') as HTMLDivElement | null;
      if (!wrap) return;
      const addItemRow = (txt = "") => {
        const row = document.createElement("div");
        row.className = "tema-item-row";
        row.innerHTML = `
          <input type="text" class="input" data-role="item-tema" placeholder="Tema o descripción" value="${txt.replace(/"/g, "&quot;")}" />
          <button type="button" class="btn-ghost text-xs" data-remove-item>Quitar</button>
        `;
        wrap.appendChild(row);
      };
      (items.length ? items : [""]).forEach((x) => addItemRow(x));

      mod.querySelector(`[data-add-item="${idx}"]`)?.addEventListener("click", () => addItemRow(""));
      mod.querySelector(`[data-remove-modulo="${idx}"]`)?.addEventListener("click", () => mod.remove());
      mod.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (target.matches("[data-remove-item]")) {
          target.closest(".tema-item-row")?.remove();
        }
      });
    }

    function serializarTemario(): CursoEditable["temas"] {
      const modulos = Array.from(document.querySelectorAll(".tema-modulo")).map((mod, i) => {
        const titulo = ((mod.querySelector('[data-role="titulo-modulo"]') as HTMLInputElement | null)?.value ?? "").trim();
        const items = Array.from(mod.querySelectorAll('[data-role="item-tema"]'))
          .map((el) => (el as HTMLInputElement).value.trim())
          .filter(Boolean);
        return { titulo, items, idx: i };
      }).filter((m) => m.items.length > 0 || m.titulo);

      if (modulos.length === 0) return [];
      const todosSinTitulo = modulos.every((m) => !m.titulo);
      if (todosSinTitulo) {
        return modulos.flatMap((m) => m.items);
      }
      return modulos.map((m, i) => ({
        titulo: m.titulo || `Módulo ${i + 1}`,
        items: m.items,
      }));
    }

    function parsearDescripcionLarga(texto: string): string[] {
      return texto
        .split(/\n\s*\n/g)
        .map((p) => p.trim())
        .filter(Boolean);
    }

    function cargarEnFormulario(curso: CursoEditable) {
      const set = (id: string, val: string | number | undefined) => { const el = $(id); if (el) el.value = val == null ? "" : String(val); };
      set("titulo", curso.titulo);
      set("subtitulo", curso.subtitulo);
      set("slug", curso.slug);
      set("descripcionCorta", curso.descripcionCorta);
      set("descripcionLarga", (curso.descripcionLarga ?? []).join("\n\n"));
      set("clases", curso.clases);
      set("modalidad", curso.modalidad);
      set("nivel", curso.nivel);
      set("inicio", curso.inicio);
      set("duracion", curso.duracion);
      set("orden", curso.orden);
      set("estado", curso.estado);
      set("simbolo", curso.simbolo);
      set("precioArgEfectivo", curso.precio?.argEfectivo);
      set("precioArgTransferencia", curso.precio?.argTransferencia);
      set("precioInternacionalUSD", curso.precio?.internacionalUSD);
      set("precioNota", curso.precio?.nota);
      set("inscripcionEmail", curso.inscripcion?.email);
      set("inscripcionWhatsapp", curso.inscripcion?.whatsapp);
      set("inscripcionLinkMercadoPago", curso.inscripcion?.linkMercadoPago);
      set("inscripcionPaypalUser", curso.inscripcion?.paypalUser);
      set("inscripcionCbu", curso.inscripcion?.cbu);
      set("inscripcionAlias", curso.inscripcion?.alias);
      set("inscripcionBanco", curso.inscripcion?.banco);
      set("inscripcionCuit", curso.inscripcion?.cuit);
      set("imagen", curso.imagen);
      set("imagenAlt", curso.imagenAlt);
      set("programaPdf", curso.programaPdf);
      set("anioOriginal", curso.anioOriginal);

      $temario!.innerHTML = "";
      const temas = curso.temas ?? [];
      if (temas.length === 0) {
        agregarModulo("", [""]);
      } else {
        const hayObjetos = temas.some((t) => typeof t === "object");
        if (!hayObjetos) {
          agregarModulo("", temas as string[]);
        } else {
          temas.forEach((t) => {
            if (typeof t === "string") agregarModulo("", [t]);
            else agregarModulo(t.titulo ?? "", t.items ?? [""]);
          });
        }
      }
    }

    function recopilarCurso(): CursoEditable {
      const get = (id: string) => ($(id)?.value ?? "").trim();
      return {
        slug: get("slug"),
        titulo: get("titulo"),
        subtitulo: get("subtitulo") || undefined,
        descripcionCorta: get("descripcionCorta"),
        descripcionLarga: parsearDescripcionLarga(get("descripcionLarga")),
        clases: Number(get("clases") || 1),
        modalidad: get("modalidad") as CursoEditable["modalidad"],
        nivel: get("nivel"),
        inicio: get("inicio") || undefined,
        duracion: get("duracion") || undefined,
        estado: get("estado") as CursoEditable["estado"],
        simbolo: get("simbolo") || "✦",
        temas: serializarTemario(),
        precio: {
          argEfectivo: get("precioArgEfectivo") || undefined,
          argTransferencia: get("precioArgTransferencia") || undefined,
          internacionalUSD: get("precioInternacionalUSD") || undefined,
          nota: get("precioNota") || undefined,
        },
        inscripcion: {
          email: get("inscripcionEmail") || undefined,
          whatsapp: get("inscripcionWhatsapp") || undefined,
          linkMercadoPago: get("inscripcionLinkMercadoPago") || undefined,
          paypalUser: get("inscripcionPaypalUser") || undefined,
          cbu: get("inscripcionCbu") || undefined,
          alias: get("inscripcionAlias") || undefined,
          banco: get("inscripcionBanco") || undefined,
          cuit: get("inscripcionCuit") || undefined,
        },
        imagen: get("imagen") || undefined,
        imagenAlt: get("imagenAlt") || undefined,
        programaPdf: get("programaPdf") || undefined,
        anioOriginal: get("anioOriginal") || undefined,
        orden: Number(get("orden") || 100),
      };
    }

    function mostrarAccionesCurso(slug: string, existe: boolean) {
      cursoExiste = existe;
      slugPersistido = slug;
      if (existe) {
        $btnPapelera?.classList.remove("hidden");
        $btnBorrar?.classList.remove("hidden");
      } else {
        $btnPapelera?.classList.add("hidden");
        $btnBorrar?.classList.add("hidden");
      }
      if ($btnVer && slug) {
        $btnVer.href = `/cursos/${encodeURIComponent(slug)}`;
        $btnVer.classList.remove("hidden");
      }
      if ($urlPublica && slug) {
        const origin = window.location.origin || "";
        $urlPublica.textContent = `URL pública: ${origin}/cursos/${slug}`;
        $urlPublica.classList.remove("hidden");
      }
    }

    function validarCurso(curso: CursoEditable): string | null {
      if (!curso.titulo) return "El título es obligatorio.";
      if (!curso.slug) return "El slug es obligatorio.";
      if (!curso.descripcionCorta) return "La descripción corta es obligatoria.";
      if (!curso.descripcionLarga.length) return "La descripción larga necesita al menos 1 párrafo.";
      if (!curso.temas.length) return "Agregá al menos un tema en el temario.";
      return null;
    }

    async function guardar(flushEstado?: CursoEditable["estado"]) {
      const curso = recopilarCurso();
      if (flushEstado) {
        curso.estado = flushEstado;
        if ($("estado")) $("estado")!.value = flushEstado;
      }
      const err = validarCurso(curso);
      if (err) {
        setStatus(err, "error");
        return null;
      }
      setStatus(flushEstado ? "Publicando curso…" : "Guardando curso…", "info");
      const r = await guardarCursoEditable(curso);
      if (!r.ok) {
        setStatus(`Error al guardar: ${r.error}`, "error");
        return null;
      }
      const slugFinal = r.slug ?? curso.slug;
      estadoPersistido = curso.estado;
      mostrarAccionesCurso(slugFinal, true);
      if (params.get("slug") !== slugFinal) {
        window.history.replaceState({}, "", `/area-reservada/cursos/editar?slug=${encodeURIComponent(slugFinal)}`);
      }
      return { ...r, slug: slugFinal };
    }

    $("titulo")?.addEventListener("input", () => {
      if (slugTocado) return;
      const slug = slugify(($("titulo")?.value ?? "").trim());
      if ($("slug")) $("slug")!.value = slug;
    });
    $("slug")?.addEventListener("input", () => { slugTocado = true; });

    document.getElementById("btn-agregar-modulo")?.addEventListener("click", () => {
      agregarModulo("", [""]);
    });

    document.getElementById("btn-simbolos")?.addEventListener("click", () => {
      $panelSimbolos?.classList.toggle("hidden");
    });

    const gridSimbolos = document.getElementById("simbolos-grid");
    if (gridSimbolos) {
      gridSimbolos.innerHTML = SIMBOLOS.map((s) => `
        <button
          type="button"
          class="simbolo-btn"
          data-simbolo="${s.simbolo}"
          title="${s.nombre}"
          aria-label="${s.nombre}"
        >
          ${s.simbolo}
        </button>
      `).join("");
      gridSimbolos.addEventListener("click", (e) => {
        const t = e.target as HTMLElement;
        const btn = t.closest("[data-simbolo]") as HTMLElement | null;
        if (!btn) return;
        const sym = btn.getAttribute("data-simbolo") ?? "✦";
        if ($("simbolo")) $("simbolo")!.value = sym;
        $panelSimbolos?.classList.add("hidden");
      });
    }
    document.addEventListener("click", (e) => {
      const target = e.target as Node;
      if (!$panelSimbolos || !$wrapSimbolos) return;
      if ($wrapSimbolos.contains(target)) return;
      $panelSimbolos.classList.add("hidden");
    });

    document.getElementById("btn-subir-imagen")?.addEventListener("click", () => {
      $inputImagen?.click();
    });
    $inputImagen?.addEventListener("change", async () => {
      const file = $inputImagen.files?.[0];
      if (!file) return;
      setStatus("Subiendo imagen…", "info");
      showLoader("Subiendo imagen…");
      try {
        const r = await subirImagenCurso(file);
        if (!r.ok || !r.url) {
          setStatus(`No se pudo subir imagen: ${r.error}`, "error");
          return;
        }
        if ($("imagen")) $("imagen")!.value = r.url;
        setStatus("Imagen subida y URL cargada.", "ok");
        $inputImagen.value = "";
      } finally {
        hideLoader();
      }
    });

    document.getElementById("btn-guardar")?.addEventListener("click", async () => {
      const estadoAntes = estadoPersistido;
      showLoader("Guardando curso…");
      try {
        const r = await guardar();
        if (!r) return;
        const estadoActual = (($("estado")?.value ?? "borrador") as CursoEditable["estado"]);
        const visAntes = estadoAntes ? ESTADOS_PUBLICOS.has(estadoAntes) : false;
        const visAhora = ESTADOS_PUBLICOS.has(estadoActual);
        if (visAntes || visAhora) {
          const dep = await dispararDeployCursos(`guardar:${r.slug}`);
          if (!dep.ok) {
            setStatus(
              `Curso guardado, pero falló el deploy automático (${dep.error}).`,
              "error",
            );
            return;
          }
        }
        setStatus(`Curso guardado. URL generada: /cursos/${r.slug}`, "ok");
      } finally {
        hideLoader();
      }
    });

    document.getElementById("btn-publicar")?.addEventListener("click", async () => {
      const estadoElegido = (($("estado")?.value ?? "") as CursoEditable["estado"]);
      if (!ESTADOS_PUBLICABLES.has(estadoElegido)) {
        await avisar(
          "Este curso no se puede publicar con estado Borrador o Archivado. Elegí un estado publicable (Activo, Próximo, Edición cerrada o Histórico) y volvé a intentar.",
        );
        setStatus(
          "Publicación bloqueada: seleccioná un estado publicable (Activo, Próximo, Edición cerrada o Histórico).",
          "error",
        );
        return;
      }
      showLoader("Publicando curso…");
      try {
        const r = await guardar(estadoElegido);
        if (!r) return;
        setStatus(`Curso publicado (${estadoElegido}). Disparando deploy del sitio…`, "info");
        const dep = await dispararDeployCursos(r.slug ?? "curso");
        if (!dep.ok) {
          setStatus(
            `Curso publicado. No pude disparar el deploy automático (${dep.error}), pero el guardado quedó correcto.`,
            "error",
          );
          return;
        }
        setStatus(
          `Curso publicado en estado ${estadoElegido}. URL generada: /cursos/${r.slug}`,
          "ok",
        );
      } finally {
        hideLoader();
      }
    });

    (async () => {
      if (slugInicial) {
        document.getElementById("estado-carga")?.classList.remove("hidden");
        const curso = await obtenerCursoEditable(slugInicial);
        document.getElementById("estado-carga")?.classList.add("hidden");
        if (curso) {
          $tituloEditor!.textContent = `Editar: ${curso.titulo}`;
          cargarEnFormulario(curso);
          estadoPersistido = curso.estado;
          mostrarAccionesCurso(curso.slug, Boolean(curso.id));
          return;
        }
        setStatus("No se encontró el curso; podés crearlo desde cero.", "info");
      }
      agregarModulo("", [""]);
      if ($("clases")) $("clases")!.value = "12";
      if ($("modalidad")) $("modalidad")!.value = "Grabado";
      if ($("estado")) $("estado")!.value = "borrador";
      estadoPersistido = "borrador";
      if ($("simbolo")) $("simbolo")!.value = "✦";
      if ($("orden")) $("orden")!.value = "100";
    })();

    $btnPapelera?.addEventListener("click", async () => {
      if (!cursoExiste) return;
      const slug = slugPersistido || ($("slug")?.value ?? "").trim();
      if (!slug) return;
      const ok = await confirmar("¿Mover este curso a la papelera? Se podrá restaurar por 30 días.");
      if (!ok) return;
      setStatus("Moviendo curso a papelera…", "info");
      showLoader("Moviendo a papelera…");
      try {
        const r = await withTimeout(moverCursoAPapelera(slug), 12000, "mover_papelera");
        if (!r.ok) {
          setStatus(`No se pudo mover a papelera: ${r.error}`, "error");
          return;
        }
        const dep = await withTimeout(
          dispararDeployCursos(`papelera:${slug}`),
          12000,
          "deploy_papelera",
        );
        if (!dep.ok) {
          setStatus(`Curso enviado a papelera, pero falló el deploy automático (${dep.error}).`, "error");
          return;
        }
        setStatus("Curso movido a la papelera.", "ok");
        setTimeout(() => { window.location.href = "/area-reservada/cursos"; }, 900);
      } catch (err) {
        console.error("[cursos.editar.moverPapelera]", err);
        setStatus(
          "La operación tardó demasiado y fue cancelada. Reintentá en unos segundos.",
          "error",
        );
      } finally {
        hideLoader();
      }
    });

    $btnBorrar?.addEventListener("click", async () => {
      if (!cursoExiste) return;
      const slug = slugPersistido || ($("slug")?.value ?? "").trim();
      if (!slug) return;
      const ok = await confirmar("¿Eliminar definitivamente este curso? Esta acción no se puede deshacer.");
      if (!ok) return;
      setStatus("Eliminando curso definitivamente…", "info");
      showLoader("Eliminando curso…");
      try {
        const r = await withTimeout(
          eliminarCursoDefinitivo(slug),
          12000,
          "eliminar_definitivo",
        );
        if (!r.ok) {
          setStatus(`No se pudo borrar definitivamente: ${r.error}`, "error");
          return;
        }
        const dep = await withTimeout(
          dispararDeployCursos(`eliminar:${slug}`),
          12000,
          "deploy_eliminar",
        );
        if (!dep.ok) {
          setStatus(`Curso eliminado de base, pero falló el deploy automático (${dep.error}).`, "error");
          return;
        }
        setStatus("Curso eliminado definitivamente.", "ok");
        setTimeout(() => { window.location.href = "/area-reservada/cursos"; }, 900);
      } catch (err) {
        console.error("[cursos.editar.eliminarDefinitivo]", err);
        setStatus(
          "La operación tardó demasiado y fue cancelada. Reintentá en unos segundos.",
          "error",
        );
      } finally {
        hideLoader();
      }
    });
  </script>
</AdminLayout>
