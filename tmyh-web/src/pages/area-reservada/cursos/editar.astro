---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Editor de curso" active="cursos">
  <a
    href="/area-reservada/cursos"
    class="text-xs uppercase tracking-widest text-parchment-300 hover:text-gold-300 transition inline-flex items-center gap-2 mb-6"
  >
    ← Volver a cursos
  </a>

  <div id="estado-carga" class="card-altar p-10 text-center hidden">
    <div class="text-2xl text-gold-400 animate-soft-pulse">☉</div>
    <p class="mt-3 text-sm text-parchment-300 font-serif italic">Cargando curso…</p>
  </div>

  <form id="form-curso" class="space-y-8" novalidate>
    <header class="flex items-start justify-between gap-4 flex-wrap">
      <div>
        <p class="title-eyebrow">Backoffice</p>
        <h1 id="titulo-editor" class="font-display text-3xl text-parchment-50 mt-3">Nuevo curso</h1>
        <p class="text-parchment-300 mt-2 font-serif italic">
          Creación y edición de ficha completa (incluye temario, precios e inscripción).
        </p>
      </div>
      <div class="flex items-center gap-2">
        <button id="btn-papelera" type="button" class="btn-ghost text-xs hidden border border-wine-500/35">
          Mover a papelera
        </button>
        <button id="btn-borrar" type="button" class="btn-ghost text-xs hidden border border-wine-500/55 text-wine-300">
          Borrar definitivo
        </button>
        <a id="btn-ver-sitio" href="#" target="_blank" rel="noopener" class="btn-ghost text-xs hidden">
          Ver en el sitio
        </a>
      </div>
      <p id="url-publica" class="hidden w-full mt-2 text-xs text-parchment-400 font-mono break-all"></p>
    </header>

    <section class="card-altar p-6 space-y-5">
      <h2 class="font-display text-xl text-parchment-50">Datos base</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="space-y-2">
          <span class="label">Título</span>
          <input id="titulo" type="text" required class="input" />
        </label>
        <label class="space-y-2">
          <span class="label">Subtítulo</span>
          <input id="subtitulo" type="text" class="input" />
        </label>
        <label class="space-y-2">
          <span class="label">Slug</span>
          <input id="slug" type="text" required class="input font-mono" />
        </label>
        <label class="space-y-2">
          <span class="label">Estado</span>
          <select id="estado" class="input">
            <option value="borrador">Borrador</option>
            <option value="activo">Activo</option>
            <option value="inactivo">Inactivo</option>
            <option value="proximo">Próximo</option>
            <option value="edicion_cerrada">Edición cerrada</option>
            <option value="historico">Histórico</option>
            <option value="archivado">Archivado</option>
          </select>
        </label>
        <label class="space-y-2">
          <span class="label">Símbolo</span>
          <div class="flex gap-2 items-start">
            <input id="simbolo" type="text" class="input" maxlength="8" />
            <div id="simbolos-popover-wrap" class="relative shrink-0">
              <button id="btn-simbolos" type="button" class="btn-ghost text-xs">Selección de símbolos</button>
              <div
                id="panel-simbolos"
                class="hidden absolute z-40 bottom-[calc(100%+10px)] left-1/2 -translate-x-1/2 w-[430px] max-w-[92vw] card-altar p-3 shadow-2xl"
              >
                <div id="simbolos-grid" class="grid grid-cols-7 gap-2"></div>
              </div>
            </div>
          </div>
        </label>
        <label class="space-y-2">
          <span class="label">Clases</span>
          <input id="clases" type="number" min="1" step="1" class="input" />
        </label>
        <label class="space-y-2">
          <span class="label">Modalidad</span>
          <select id="modalidad" class="input">
            <option>Grabado</option>
            <option>Online en vivo</option>
            <option>Híbrido</option>
          </select>
        </label>
        <label class="space-y-2">
          <span class="label">Nivel</span>
          <input id="nivel" type="text" class="input" />
        </label>
        <label class="space-y-2">
          <span class="label">Inicio</span>
          <input id="inicio" type="text" class="input" />
        </label>
        <label class="space-y-2">
          <span class="label">Duración</span>
          <input id="duracion" type="text" class="input" />
        </label>
        <label class="space-y-2">
          <span class="label">Orden en grilla</span>
          <input id="orden" type="number" min="1" step="1" class="input" />
        </label>
        <label class="space-y-2 md:col-span-2">
          <span class="label">Descripción corta</span>
          <textarea id="descripcionCorta" rows="3" class="input"></textarea>
        </label>
        <label class="space-y-2 md:col-span-2">
          <span class="label">Descripción larga (párrafos separados por línea en blanco)</span>
          <textarea id="descripcionLarga" rows="8" class="input"></textarea>
        </label>
      </div>
    </section>

    <section class="card-altar p-6 space-y-4">
      <div class="flex items-center justify-between gap-3 flex-wrap">
        <h2 class="font-display text-xl text-parchment-50">Temario</h2>
        <button id="btn-agregar-modulo" type="button" class="btn-ghost text-xs h-10 px-5">+ Agregar módulo</button>
      </div>
      <div id="temario-modulos" class="space-y-4"></div>
      <p class="text-xs text-parchment-400">
        Si dejás todos los títulos de módulo vacíos, el sistema guarda una lista simple (estilo Simbología).
      </p>
    </section>

    <section class="card-altar p-6 space-y-5">
      <h2 class="font-display text-xl text-parchment-50">Precios e inscripción</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="space-y-2"><span class="label">Precio ARS</span><input id="precioArgEfectivo" type="text" class="input" /></label>
        <label class="space-y-2"><span class="label">Precio ARS transferencia</span><input id="precioArgTransferencia" type="text" class="input" /></label>
        <label class="space-y-2"><span class="label">Precio internacional (USD)</span><input id="precioInternacionalUSD" type="text" class="input" /></label>
        <label class="space-y-2 md:col-span-2"><span class="label">Nota precio</span><input id="precioNota" type="text" class="input" /></label>
        <label class="space-y-2"><span class="label">Email</span><input id="inscripcionEmail" type="text" class="input" /></label>
        <label class="space-y-2"><span class="label">WhatsApp (sin +)</span><input id="inscripcionWhatsapp" type="text" class="input" /></label>
        <label class="space-y-2"><span class="label">Link MercadoPago</span><input id="inscripcionLinkMercadoPago" type="text" class="input" /></label>
        <label class="space-y-2"><span class="label">Usuario PayPal.me</span><input id="inscripcionPaypalUser" type="text" class="input" /></label>
        <label class="space-y-2"><span class="label">Banco</span><input id="inscripcionBanco" type="text" class="input" /></label>
        <label class="space-y-2"><span class="label">CBU</span><input id="inscripcionCbu" type="text" class="input font-mono" /></label>
        <label class="space-y-2"><span class="label">Alias</span><input id="inscripcionAlias" type="text" class="input font-mono" /></label>
        <label class="space-y-2"><span class="label">CUIT</span><input id="inscripcionCuit" type="text" class="input font-mono" /></label>
      </div>
    </section>

    <section class="card-altar p-6 space-y-5">
      <h2 class="font-display text-xl text-parchment-50">Recursos y metadata</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="space-y-2">
          <span class="label">Imagen (nombre archivo o URL)</span>
          <div class="flex gap-2">
            <input id="imagen" type="text" class="input" />
            <button id="btn-subir-imagen" type="button" class="btn-ghost text-xs shrink-0">Adjuntar imagen</button>
          </div>
          <p class="text-[11px] text-parchment-400">Opcional. Puede ser nombre local o URL pública (Storage).</p>
        </label>
        <label class="space-y-2"><span class="label">Imagen alt</span><input id="imagenAlt" type="text" class="input" /></label>
        <label class="space-y-2"><span class="label">Programa PDF (archivo en /public/assets)</span><input id="programaPdf" type="text" class="input" /></label>
        <label class="space-y-2"><span class="label">Año original</span><input id="anioOriginal" type="text" class="input" /></label>
      </div>
    </section>

    <div id="status" class="hidden text-sm font-serif italic" role="status" aria-live="polite"></div>

    <div class="flex items-center gap-3 flex-wrap pt-2 border-t border-gold-400/10">
      <button id="btn-guardar" type="button" class="btn-gold">Guardar curso</button>
      <button id="btn-publicar" type="button" class="btn-ghost border border-gold-400/35">Publicar</button>
      <a href="/area-reservada/cursos" class="btn-ghost">Cancelar</a>
    </div>
  </form>

  <input id="input-imagen" type="file" accept="image/*" class="hidden" />

  <style is:global>
    #form-curso .label {
      display: block;
      font-family: var(--font-sans);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-parchment-400);
    }
    #form-curso .input {
      width: 100%;
      background: rgb(7 6 13 / 0.6);
      border: 1px solid rgb(230 196 100 / 0.15);
      color: var(--color-parchment-100);
      padding: 0.7rem 0.85rem;
      border-radius: 2px;
      outline: none;
      transition: border-color 180ms ease;
    }
    #form-curso .input:focus { border-color: rgb(230 196 100 / 0.6); }
    #form-curso .tema-modulo {
      border: 1px solid rgb(230 196 100 / 0.15);
      border-radius: 2px;
      padding: 1rem;
      width: 100%;
    }
    #form-curso [data-role="items-wrap"] {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    #form-curso .tema-item-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 112px;
      gap: 0.6rem;
      width: 100%;
      align-items: center;
    }
    #form-curso .tema-item-row [data-role="item-tema"] { min-width: 0; width: 100%; }
    #form-curso .tema-item-row [data-remove-item] { height: 2.85rem; }
    #simbolos-popover-wrap .simbolo-btn {
      width: 100%;
      aspect-ratio: 1 / 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgb(230 196 100 / 0.2);
      border-radius: 2px;
      background: rgb(7 6 13 / 0.65);
      color: var(--color-gold-300);
      font-size: 2rem;
      line-height: 1;
      transition: all 160ms ease;
    }
    #simbolos-popover-wrap .simbolo-btn:hover {
      color: var(--color-gold-200);
      border-color: rgb(230 196 100 / 0.45);
      background: rgb(230 196 100 / 0.08);
      transform: translateY(-1px);
    }
  </style>

  <script>
    import {
      obtenerCursoEditable,
      guardarCursoEditable,
      moverCursoAPapelera,
      eliminarCursoDefinitivo,
      dispararDeployCursos,
      subirImagenCurso,
      type CursoEditable,
    } from "../../../lib/cursos-cms";

    const $ = (id: string) => document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
    const $status = document.getElementById("status");
    const $temario = document.getElementById("temario-modulos");
    const $tituloEditor = document.getElementById("titulo-editor");
    const $btnVer = document.getElementById("btn-ver-sitio") as HTMLAnchorElement | null;
    const $btnPapelera = document.getElementById("btn-papelera") as HTMLButtonElement | null;
    const $btnBorrar = document.getElementById("btn-borrar") as HTMLButtonElement | null;
    const $urlPublica = document.getElementById("url-publica") as HTMLParagraphElement | null;
    const $panelSimbolos = document.getElementById("panel-simbolos");
    const $wrapSimbolos = document.getElementById("simbolos-popover-wrap");
    const $inputImagen = document.getElementById("input-imagen") as HTMLInputElement | null;
    const params = new URLSearchParams(window.location.search);
    const slugInicial = (params.get("slug") ?? "").trim();
    let slugPersistido = slugInicial;
    let slugTocado = false;
    let cursoExiste = false;
    let estadoPersistido: CursoEditable["estado"] | null = null;
    let loaderFallback: HTMLDivElement | null = null;
    let loaderWatchdog: ReturnType<typeof setTimeout> | null = null;
    const ESTADOS_PUBLICABLES = new Set<CursoEditable["estado"]>([
      "activo",
      "proximo",
      "edicion_cerrada",
      "historico",
    ]);
    const ESTADOS_PUBLICOS = new Set<CursoEditable["estado"]>([
      "activo",
      "proximo",
      "edicion_cerrada",
      "historico",
    ]);
    const SIMBOLOS: Array<{ simbolo: string; nombre: string }> = [
