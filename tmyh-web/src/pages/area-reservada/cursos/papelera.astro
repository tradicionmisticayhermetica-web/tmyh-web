---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Papelera cursos" active="cursos">
  <header class="mb-8 flex items-end justify-between gap-4 flex-wrap">
    <div>
      <p class="title-eyebrow">Backoffice</p>
      <h1 class="font-display text-3xl text-parchment-50 mt-3">Papelera de cursos</h1>
      <p class="text-parchment-300 mt-2 font-serif italic">
        Cursos eliminados. Se purgan automáticamente tras 30 días.
      </p>
    </div>
    <a href="/area-reservada/cursos" class="btn-ghost">← Volver</a>
  </header>

  <section id="lista-papelera" class="space-y-4">
    <div class="card-altar p-10 text-center text-parchment-400 text-sm font-serif italic">
      Cargando…
    </div>
  </section>

  <div id="status" class="hidden mt-5 text-sm font-serif italic" role="status" aria-live="polite"></div>

  <div id="dialog-confirm" class="fixed inset-0 z-[120] hidden items-center justify-center p-4 bg-midnight-950/78">
    <div class="card-altar w-full max-w-lg p-6">
      <h3 class="font-display text-xl text-parchment-50 mb-3">Confirmación</h3>
      <p id="dialog-confirm-msg" class="text-parchment-200 font-serif"></p>
      <div class="mt-6 flex items-center justify-end gap-2">
        <button id="dialog-confirm-cancel" type="button" class="btn-ghost">Cancelar</button>
        <button id="dialog-confirm-ok" type="button" class="btn-gold">Aceptar</button>
      </div>
    </div>
  </div>

  <script>
    import {
      listarCursosPapelera,
      restaurarCursoDePapelera,
      eliminarCursoDefinitivo,
      purgarCursosPapelera,
      dispararDeployCursos,
    } from "../../../lib/cursos-cms";

    const lista = document.getElementById("lista-papelera");
    const status = document.getElementById("status");
    let loaderFallback: HTMLDivElement | null = null;

    function setStatus(msg: string, tipo: "ok" | "error" | "info") {
      if (!status) return;
      status.textContent = msg;
      status.classList.remove("hidden", "text-gold-300", "text-wine-500", "text-parchment-300");
      status.classList.add(tipo === "ok" ? "text-gold-300" : tipo === "error" ? "text-wine-500" : "text-parchment-300");
    }

    function ensureLoaderFallback() {
      if (loaderFallback) return loaderFallback;
      const wrap = document.createElement("div");
      wrap.className = "hidden fixed inset-0 z-[1400] items-center justify-center bg-night-950/78 backdrop-blur-[2px]";
      wrap.innerHTML = `
        <div class="card-altar px-8 py-7 text-center min-w-[300px]">
          <div class="loader-triad" aria-hidden="true">
            <span class="loader-sym m">☿</span>
            <span class="loader-sym a">🜍</span>
            <span class="loader-sym s">🜔</span>
          </div>
          <p class="loader-msg mt-5 text-xs tracking-widest uppercase text-parchment-200">Procesando…</p>
        </div>`;
      document.body.appendChild(wrap);
      loaderFallback = wrap;
      return wrap;
    }

    function showLoader(msg = "Procesando…") {
      const uiLoader = (window as any).__tmyhLoader;
      if (uiLoader?.show) {
        uiLoader.show(msg);
        return;
      }
      const wrap = ensureLoaderFallback();
      const msgEl = wrap.querySelector(".loader-msg");
      if (msgEl) msgEl.textContent = msg;
      wrap.classList.remove("hidden");
      wrap.classList.add("flex");
    }

    function hideLoader() {
      const uiLoader = (window as any).__tmyhLoader;
      if (uiLoader?.hide) {
        uiLoader.hide();
        return;
      }
      if (!loaderFallback) return;
      loaderFallback.classList.add("hidden");
      loaderFallback.classList.remove("flex");
    }

    function confirmar(msg: string): Promise<boolean> {
      return new Promise((resolve) => {
        const dlg = document.getElementById("dialog-confirm");
        const txt = document.getElementById("dialog-confirm-msg");
        const ok = document.getElementById("dialog-confirm-ok");
        const cancel = document.getElementById("dialog-confirm-cancel");
        if (!dlg || !txt || !ok || !cancel) return resolve(window.confirm(msg));
        txt.textContent = msg;
        dlg.classList.remove("hidden");
        dlg.classList.add("flex");
        const cleanup = () => {
          dlg.classList.add("hidden");
          dlg.classList.remove("flex");
          ok.removeEventListener("click", onOk);
          cancel.removeEventListener("click", onCancel);
        };
        const onOk = () => {
          cleanup();
          resolve(true);
        };
        const onCancel = () => {
          cleanup();
          resolve(false);
        };
        ok.addEventListener("click", onOk);
        cancel.addEventListener("click", onCancel);
      });
    }

    function escapeHtml(s: string): string {
      return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }

    function formatearFecha(iso: string | null | undefined): string {
      if (!iso) return "—";
      try {
        return new Date(iso).toLocaleString("es-AR", {
          day: "2-digit", month: "short", year: "numeric", hour: "2-digit", minute: "2-digit",
        });
      } catch {
        return iso;
      }
    }

    async function cargar() {
      showLoader("Cargando papelera…");
      let cursos: Awaited<ReturnType<typeof listarCursosPapelera>> = [];
      try {
        await purgarCursosPapelera();
        cursos = await listarCursosPapelera();
      } finally {
        hideLoader();
      }
      if (!lista) return;
      if (cursos.length === 0) {
        lista.innerHTML = `
          <div class="card-altar p-12 text-center">
            <p class="text-parchment-300 font-serif italic">No hay cursos en papelera.</p>
          </div>`;
        return;
      }

      lista.innerHTML = cursos.map((c) => `
        <article class="card-altar p-6">
          <div class="flex items-start justify-between gap-4 flex-wrap">
            <div class="min-w-0 flex-1">
              <div class="font-display text-xl text-parchment-50">${escapeHtml(c.titulo)}</div>
              <div class="text-xs text-parchment-500 font-mono mt-1">/cursos/${escapeHtml(c.slug)}</div>
              <p class="text-sm text-parchment-300 mt-3 font-serif">${escapeHtml(c.descripcionCorta)}</p>
              <div class="text-[11px] uppercase tracking-widest text-parchment-400 mt-4">
                eliminado: ${escapeHtml(formatearFecha(c.eliminadoEn))}
              </div>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <button data-restaurar="${encodeURIComponent(c.slug)}" class="btn-ghost text-xs">Restaurar</button>
              <button data-eliminar="${encodeURIComponent(c.slug)}" class="btn-ghost text-xs border border-wine-500/35 text-wine-400">Eliminar definitivo</button>
            </div>
          </div>
        </article>
      `).join("");

      lista.querySelectorAll<HTMLButtonElement>("[data-restaurar]").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const slug = decodeURIComponent(btn.dataset.restaurar ?? "");
          if (!slug) return;
          showLoader("Restaurando curso…");
          try {
            const r = await restaurarCursoDePapelera(slug);
            if (!r.ok) {
              setStatus(`No se pudo restaurar: ${r.error}`, "error");
              return;
            }
            const dep = await dispararDeployCursos(`restaurar:${slug}`);
            if (!dep.ok) {
              setStatus(`Curso restaurado, pero falló el deploy automático (${dep.error}).`, "error");
              return;
            }
            setStatus("Curso restaurado correctamente.", "ok");
            await cargar();
          } finally {
            hideLoader();
          }
        });
      });
      lista.querySelectorAll<HTMLButtonElement>("[data-eliminar]").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const slug = decodeURIComponent(btn.dataset.eliminar ?? "");
          if (!slug) return;
          if (!await confirmar("¿Eliminar definitivamente este curso? Esta acción no se puede deshacer.")) return;
          showLoader("Eliminando curso…");
          try {
            const r = await eliminarCursoDefinitivo(slug);
            if (!r.ok) {
              setStatus(`No se pudo eliminar: ${r.error}`, "error");
              return;
            }
            const dep = await dispararDeployCursos(`eliminar:${slug}`);
            if (!dep.ok) {
              setStatus(`Curso eliminado de base, pero falló el deploy automático (${dep.error}).`, "error");
              return;
            }
            setStatus("Curso eliminado definitivamente.", "ok");
            await cargar();
          } finally {
            hideLoader();
          }
        });
      });
    }

    cargar();
  </script>
</AdminLayout>
