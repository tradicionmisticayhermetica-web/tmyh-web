---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Papelera mensajes" active="mensajes">
  <header class="mb-8 flex items-end justify-between gap-4 flex-wrap">
    <div>
      <p class="title-eyebrow">Bandeja</p>
      <h1 class="font-display text-3xl text-parchment-50 mt-3">Papelera de mensajes</h1>
      <p class="text-parchment-300 mt-2 font-serif italic">
        Mensajes eliminados. Podés restaurarlos o eliminarlos definitivamente.
      </p>
    </div>
    <a href="/area-reservada/mensajes" class="btn-ghost">← Volver</a>
  </header>

  <section id="lista-papelera" class="card-altar divide-y divide-gold-400/10">
    <div class="py-12 text-center text-parchment-400 text-sm font-serif italic">
      Cargando papelera…
    </div>
  </section>

  <div id="status" class="hidden mt-5 text-sm font-serif italic" role="status" aria-live="polite"></div>

  <script>
    import {
      listarMensajesPapelera,
      restaurarMensajeDePapelera,
      eliminarMensajeDefinitivo,
      purgarMensajesPapelera,
      formatearFecha,
      nombreCompleto,
      type MensajeContacto,
    } from "../../../lib/admin";

    const lista = document.getElementById("lista-papelera");
    const status = document.getElementById("status");

    function setStatus(msg: string, tipo: "ok" | "error" | "info") {
      if (!status) return;
      status.textContent = msg;
      status.classList.remove("hidden", "text-gold-300", "text-wine-500", "text-parchment-300");
      status.classList.add(tipo === "ok" ? "text-gold-300" : tipo === "error" ? "text-wine-500" : "text-parchment-300");
    }

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function confirmar(msg: string): Promise<boolean> {
      return new Promise((resolve) => {
        const overlay = document.createElement("div");
        overlay.className = "fixed inset-0 z-[998] flex items-center justify-center bg-night-950/80 backdrop-blur-sm";
        overlay.innerHTML = `
          <div class="card-altar p-8 max-w-md mx-4 space-y-5">
            <p class="font-serif text-base text-parchment-100 leading-relaxed">${msg}</p>
            <div class="flex gap-3 justify-end">
              <button id="conf-cancel" class="btn-ghost text-sm">Cancelar</button>
              <button id="conf-ok" class="btn-gold text-sm">Confirmar</button>
            </div>
          </div>`;
        document.body.appendChild(overlay);
        overlay.querySelector("#conf-ok")?.addEventListener("click", () => { overlay.remove(); resolve(true); });
        overlay.querySelector("#conf-cancel")?.addEventListener("click", () => { overlay.remove(); resolve(false); });
        overlay.addEventListener("click", (e) => { if (e.target === overlay) { overlay.remove(); resolve(false); } });
      });
    }

    function pintar(mensajes: MensajeContacto[]) {
      if (!lista) return;
      if (mensajes.length === 0) {
        lista.innerHTML = `
          <div class="py-16 text-center">
            <div class="text-2xl text-gold-400 mb-3 opacity-50">☉</div>
            <p class="text-parchment-300 font-serif italic">La papelera está vacía.</p>
          </div>
        `;
        return;
      }

      lista.innerHTML = mensajes
        .map((m) => {
          const dias = m.eliminado_en
            ? Math.max(0, Math.floor((Date.now() - new Date(m.eliminado_en).getTime()) / (1000 * 60 * 60 * 24)))
            : 0;
          const diasRestantes = Math.max(0, 30 - dias);
          return `
            <article class="px-6 py-5">
              <div class="flex items-start justify-between gap-4 flex-wrap">
                <div class="min-w-0 flex-1">
                  <div class="font-display text-parchment-50">${escapeHtml(nombreCompleto(m))}</div>
                  <div class="text-xs text-parchment-400 mt-0.5">${escapeHtml(m.email)}</div>
                  ${m.curso_interes ? `<div class="text-xs text-gold-300 mt-1.5">${escapeHtml(m.curso_interes)}</div>` : ""}
                  <p class="text-sm text-parchment-300 mt-2 font-serif">${escapeHtml(m.mensaje)}</p>
                  <div class="text-[11px] uppercase tracking-widest text-parchment-400 mt-3">
                    En papelera hace ${dias} ${dias === 1 ? "día" : "días"} · quedan ${diasRestantes} días
                  </div>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <button data-restaurar="${m.id}" class="btn-ghost text-xs">Restaurar</button>
                  <button data-eliminar="${m.id}" class="btn-ghost text-xs border border-wine-500/35 text-wine-400">
                    Eliminar definitivo
                  </button>
                </div>
              </div>
            </article>
          `;
        })
        .join("");

      lista.querySelectorAll<HTMLButtonElement>("[data-restaurar]").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const id = btn.dataset.restaurar ?? "";
          if (!id) return;
          const ok = await confirmar("¿Restaurar este mensaje a la bandeja principal?");
          if (!ok) return;
          const r = await restaurarMensajeDePapelera(id);
          if (!r.ok) {
            setStatus(`No se pudo restaurar: ${r.error}`, "error");
            return;
          }
          setStatus("Mensaje restaurado.", "ok");
          await cargar();
        });
      });

      lista.querySelectorAll<HTMLButtonElement>("[data-eliminar]").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const id = btn.dataset.eliminar ?? "";
          if (!id) return;
          const ok = await confirmar("¿Eliminar definitivamente este mensaje? Esta acción no se puede deshacer.");
          if (!ok) return;
          const r = await eliminarMensajeDefinitivo(id);
          if (!r.ok) {
            setStatus(`No se pudo eliminar: ${r.error}`, "error");
            return;
          }
          setStatus("Mensaje eliminado definitivamente.", "ok");
          await cargar();
        });
      });
    }

    async function cargar() {
      await purgarMensajesPapelera();
      const mensajes = await listarMensajesPapelera(300);
      pintar(mensajes);
    }

    cargar();
  </script>
</AdminLayout>
