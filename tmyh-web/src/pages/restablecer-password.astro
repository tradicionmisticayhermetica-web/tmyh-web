---
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#07060d" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Restablecer contraseña · Tradición Mística y Hermética</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500;600&display=swap"
    />
  </head>

  <body class="min-h-screen flex flex-col">
    <main
      class="flex-1 flex items-center justify-center px-6 py-12 relative"
    >
      <div class="stars-bg" aria-hidden="true"></div>

      <div class="relative w-full max-w-md">
        <div class="text-center mb-8">
          <a
            href="/"
            class="inline-flex items-center gap-3 text-parchment-300 hover:text-gold-300 transition"
          >
            <span class="text-xl text-gold-400">☉</span>
            <span class="font-display text-sm tracking-widest"
              >Tradición Mística y Hermética</span
            >
          </a>
        </div>

        <div class="card-altar p-8 lg:p-10">
          {/* Pantalla de carga inicial */}
          <div id="reset-loading" class="text-center py-6">
            <div class="text-2xl text-gold-400 animate-soft-pulse">☉</div>
            <p class="mt-3 text-xs text-parchment-300 tracking-widest uppercase">
              Verificando link
            </p>
          </div>

          {/* Form solo se muestra si el token es valido */}
          <div id="reset-form-wrap" class="hidden">
            <div class="text-center mb-8">
              <div class="title-eyebrow mb-4">Nueva contraseña</div>
              <h1 class="font-display text-2xl text-parchment-50 mt-2">
                Restablecer acceso
              </h1>
              <p
                class="text-sm text-parchment-300 mt-3 font-serif italic text-balance"
              >
                Ingresá tu nueva contraseña.
                <span id="reset-email" class="text-gold-300 not-italic"></span>
              </p>
            </div>

            <form id="form-nueva" class="space-y-5" novalidate>
              <div>
                <label
                  for="password"
                  class="block text-[11px] uppercase tracking-widest text-parchment-400 mb-2"
                  >Nueva contraseña</label
                >
                <input
                  id="password"
                  name="password"
                  type="password"
                  required
                  minlength="6"
                  autocomplete="new-password"
                  class="w-full bg-night-950/60 border border-gold-400/15 focus:border-gold-400/60 outline-none text-parchment-100 px-4 py-2.5 text-sm font-sans transition rounded-sm"
                />
                <p
                  class="text-[10px] uppercase tracking-widest text-parchment-400 mt-2"
                >
                  Mínimo 6 caracteres
                </p>
              </div>

              <div>
                <label
                  for="password2"
                  class="block text-[11px] uppercase tracking-widest text-parchment-400 mb-2"
                  >Repetir contraseña</label
                >
                <input
                  id="password2"
                  name="password2"
                  type="password"
                  required
                  minlength="6"
                  autocomplete="new-password"
                  class="w-full bg-night-950/60 border border-gold-400/15 focus:border-gold-400/60 outline-none text-parchment-100 px-4 py-2.5 text-sm font-sans transition rounded-sm"
                />
              </div>

              <div
                id="reset-status"
                class="hidden text-sm font-serif italic px-1"
                role="status"
                aria-live="polite"
              >
              </div>

              <button
                id="btn-guardar"
                type="submit"
                class="btn-gold w-full justify-center"
              >
                Guardar contraseña
              </button>
            </form>
          </div>

          {/* Pantalla de error si el link no es valido */}
          <div id="reset-invalido" class="hidden text-center py-6">
            <div class="text-2xl text-wine-600 mb-3">⚠</div>
            <h2 class="font-display text-lg text-parchment-50">
              Link inválido o expirado
            </h2>
            <p class="text-sm text-parchment-300 mt-3 font-serif italic">
              El enlace de recuperación pudo haberse vencido o ya fue usado.
              Pedí uno nuevo.
            </p>
            <a
              href="/recuperar-password"
              class="btn-ghost mt-6 inline-flex"
            >
              Pedir nuevo link
            </a>
          </div>

          <div class="ornament my-6" aria-hidden="true" style="opacity:0.4">
            <span>☉</span>
          </div>

          <p class="text-center text-xs text-parchment-400">
            <a href="/login" class="link-subtle">← Volver al inicio de sesión</a>
          </p>
        </div>
      </div>
    </main>

    <script>
      import { supabase } from "../lib/supabase";
      import { actualizarPassword } from "../lib/auth";

      const loading = document.getElementById("reset-loading");
      const formWrap = document.getElementById("reset-form-wrap");
      const invalido = document.getElementById("reset-invalido");
      const status = document.getElementById("reset-status");

      function mostrarStatus(msg: string, tipo: "ok" | "error") {
        if (!status) return;
        status.textContent = msg;
        status.classList.remove("hidden", "text-gold-300", "text-wine-600");
        status.classList.add(
          tipo === "ok" ? "text-gold-300" : "text-wine-600",
        );
      }

      function show(el: HTMLElement | null) {
        el?.classList.remove("hidden");
      }
      function hide(el: HTMLElement | null) {
        el?.classList.add("hidden");
      }

      // El SDK de Supabase tiene `detectSessionInUrl: true`, asi que cuando
      // el usuario llega desde el link del mail (con #access_token=...&type=
      // recovery), procesa los tokens automaticamente y crea sesion temporal.
      // Esperamos a que termine y verificamos.
      async function init() {
        // Damos un microtick para que el SDK procese el hash si existe.
        await new Promise((r) => setTimeout(r, 50));

        const { data } = await supabase.auth.getSession();

        if (!data.session) {
          hide(loading);
          show(invalido);
          return;
        }

        const email = data.session.user.email ?? "";
        const emailEl = document.getElementById("reset-email");
        if (emailEl && email) emailEl.textContent = `(${email})`;

        hide(loading);
        show(formWrap);
      }

      init();

      const form = document.getElementById("form-nueva") as HTMLFormElement | null;
      const btn = document.getElementById("btn-guardar") as HTMLButtonElement | null;

      form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!btn) return;

        const fd = new FormData(form);
        const p1 = String(fd.get("password") ?? "");
        const p2 = String(fd.get("password2") ?? "");

        if (p1.length < 6) {
          mostrarStatus("La contraseña debe tener al menos 6 caracteres.", "error");
          return;
        }
        if (p1 !== p2) {
          mostrarStatus("Las contraseñas no coinciden.", "error");
          return;
        }

        btn.disabled = true;
        btn.textContent = "Guardando…";
        if (status) status.classList.add("hidden");

        const r = await actualizarPassword(p1);

        if (r.ok) {
          mostrarStatus(
            "Contraseña actualizada. Redirigiendo al panel…",
            "ok",
          );
          btn.textContent = "Listo ✓";
          // El SDK ya tiene sesion abierta despues del recovery, asi que
          // mandamos directo a /area-reservada (si tiene rol admin).
          setTimeout(() => {
            window.location.href = "/area-reservada";
          }, 1200);
          return;
        }

        const errores: Record<string, string> = {
          password_corta: "La contraseña debe tener al menos 6 caracteres.",
          password_iguales:
            "La nueva contraseña tiene que ser distinta a la anterior.",
          no_autenticado:
            "El link expiró. Pedí uno nuevo desde \"Olvidaste tu contraseña\".",
          red: "No pude conectar con el servidor. Probá de nuevo.",
          config: "Configuración faltante.",
        };
        mostrarStatus(errores[r.error ?? ""] ?? "Algo salió mal.", "error");
        btn.disabled = false;
        btn.textContent = "Guardar contraseña";
      });
    </script>
  </body>
</html>
