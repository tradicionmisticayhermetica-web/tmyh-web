---
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#07060d" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Recuperar contraseña · Tradición Mística y Hermética</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500;600&display=swap"
    />
  </head>

  <body class="min-h-screen flex flex-col">
    <main
      class="flex-1 flex items-center justify-center px-6 py-12 relative"
    >
      <div class="stars-bg" aria-hidden="true"></div>

      <div class="relative w-full max-w-md">
        <div class="text-center mb-8">
          <a
            href="/"
            class="inline-flex items-center gap-3 text-parchment-300 hover:text-gold-300 transition"
          >
            <span class="text-xl text-gold-400">☉</span>
            <span class="font-display text-sm tracking-widest"
              >Tradición Mística y Hermética</span
            >
          </a>
        </div>

        <div class="card-altar p-8 lg:p-10">
          <div class="text-center mb-8">
            <div class="title-eyebrow mb-4">Recuperar acceso</div>
            <h1 class="font-display text-2xl text-parchment-50 mt-2">
              ¿Olvidaste tu contraseña?
            </h1>
            <p
              class="text-sm text-parchment-300 mt-3 font-serif italic text-balance"
            >
              Ingresá el email de tu cuenta y te enviamos un link para
              restablecerla.
            </p>
          </div>

          <form id="form-reset" class="space-y-5" novalidate>
            <div>
              <label
                for="email"
                class="block text-[11px] uppercase tracking-widest text-parchment-400 mb-2"
                >Correo</label
              >
              <input
                id="email"
                name="email"
                type="email"
                required
                autocomplete="email"
                class="w-full bg-night-950/60 border border-gold-400/15 focus:border-gold-400/60 outline-none text-parchment-100 px-4 py-2.5 text-sm font-sans transition rounded-sm"
              />
            </div>

            <div
              id="reset-status"
              class="hidden text-sm font-serif italic px-1"
              role="status"
              aria-live="polite"
            >
            </div>

            <button
              id="btn-reset"
              type="submit"
              class="btn-gold w-full justify-center"
            >
              Enviar link
            </button>
          </form>

          <div class="ornament my-6" aria-hidden="true" style="opacity:0.4">
            <span>☉</span>
          </div>

          <p class="text-center text-xs text-parchment-400">
            <a href="/login" class="link-subtle">← Volver al inicio de sesión</a>
          </p>
        </div>
      </div>
    </main>

    <script>
      import { solicitarResetPassword } from "../lib/auth";

      const form = document.getElementById("form-reset") as HTMLFormElement | null;
      const status = document.getElementById("reset-status");
      const btn = document.getElementById("btn-reset") as HTMLButtonElement | null;

      function mostrarStatus(msg: string, tipo: "ok" | "error") {
        if (!status) return;
        status.textContent = msg;
        status.classList.remove("hidden", "text-gold-300", "text-wine-600");
        status.classList.add(
          tipo === "ok" ? "text-gold-300" : "text-wine-600",
        );
      }

      form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!btn) return;

        const fd = new FormData(form);
        const email = String(fd.get("email") ?? "").trim();

        if (!email) {
          mostrarStatus("Ingresá tu email.", "error");
          return;
        }

        btn.disabled = true;
        btn.textContent = "Enviando…";
        if (status) status.classList.add("hidden");

        const r = await solicitarResetPassword(email);

        if (r.ok) {
          mostrarStatus(
            "Si el email está registrado, vas a recibir un mensaje con instrucciones para restablecer tu contraseña. Revisá la bandeja de entrada y la carpeta de spam.",
            "ok",
          );
          btn.textContent = "Enviado ✓";
          form.reset();
          // No reactivamos el boton, evitamos spam de pedidos.
          return;
        }

        const errores: Record<string, string> = {
          email_invalido: "El email no es válido.",
          rate_limit: "Demasiados intentos. Probá de nuevo en unos minutos.",
          red: "No pude conectar con el servidor. Probá de nuevo.",
          config: "Configuración faltante. Avisá al administrador.",
        };
        mostrarStatus(errores[r.error ?? ""] ?? "Algo salió mal.", "error");
        btn.disabled = false;
        btn.textContent = "Enviar link";
      });
    </script>
  </body>
</html>
