---
/**
 * Editor de blog enriquecido para /area-reservada/blog.
 *
 * Usa Tiptap: texto, imagen/vídeo/PDF (subida o URL con ⌗), YouTube, tablas en dos columnas.
 *
 * Emite un evento custom "editor:change" con el detalle:
 *   { json: object, html: string }
 *
 * Uso:
 *   <EditorBlog
 *     initialJson={post.contenido_json}
 *     placeholder="Empezá a escribir…"
 *   />
 *
 * client:load es requerido (Tiptap es puro browser).
 */
interface Props {
  initialJson?: unknown;
  placeholder?: string;
}

const {
  initialJson,
  placeholder = "Comenzá a escribir la reflexión…",
} = Astro.props;
---

<div
  id="editor-blog-root"
  class="editor-blog-wrapper"
  data-initial={JSON.stringify(initialJson ?? null)}
  data-placeholder={placeholder}
>
  <!-- Barra de herramientas -->
  <div
    id="editor-toolbar"
    class="editor-toolbar flex flex-wrap gap-1.5 p-2.5 border-b border-gold-400/15 bg-night-950/50"
    role="toolbar"
    aria-label="Herramientas de edición"
  >
    <!-- Bloque: texto -->
    <div class="flex gap-1">
      <button type="button" data-cmd="bold" title="Negrita" class="tb-btn">
        <strong>N</strong>
      </button>
      <button type="button" data-cmd="italic" title="Cursiva" class="tb-btn italic">
        I
      </button>
    </div>

    <div class="tb-divider"></div>

    <!-- Bloque: encabezados -->
    <div class="flex gap-1">
      <button type="button" data-cmd="h2" title="Título" class="tb-btn font-display">
        H2
      </button>
      <button type="button" data-cmd="h3" title="Subtítulo" class="tb-btn font-display">
        H3
      </button>
    </div>

    <div class="tb-divider"></div>

    <!-- Bloque: bloques especiales -->
    <div class="flex gap-1">
      <button type="button" data-cmd="blockquote" title="Cita" class="tb-btn">
        ❝
      </button>
      <button type="button" data-cmd="bulletList" title="Lista" class="tb-btn">
        ☰
      </button>
      <button type="button" data-cmd="orderedList" title="Lista numerada" class="tb-btn">
        №
      </button>
      <button type="button" data-cmd="horizontalRule" title="Separador ☉" class="tb-btn text-gold-400">
        ☉
      </button>
    </div>

    <div class="tb-divider"></div>

    <!-- Bloque: media y maquetación -->
    <div class="flex gap-1">
      <button type="button" data-cmd="link" title="Insertar link" class="tb-btn">
        🔗
      </button>
      <button type="button" data-cmd="media" title="Subir imagen, vídeo o PDF desde tu equipo" class="tb-btn">
        🖼
      </button>
      <button type="button" data-cmd="mediaUrl" title="Insertar desde URL: imagen, vídeo, PDF o YouTube" class="tb-btn">
        ⌗
      </button>
      <button type="button" data-cmd="twoCol" title="Dos columnas: texto e imagen lado a lado" class="tb-btn font-display text-[10px] px-1.5">
        ⊞
      </button>
    </div>

    <div class="tb-divider"></div>

    <!-- Deshacer / Rehacer -->
    <div class="flex gap-1">
      <button type="button" data-cmd="undo" title="Deshacer" class="tb-btn opacity-70">
        ↩
      </button>
      <button type="button" data-cmd="redo" title="Rehacer" class="tb-btn opacity-70">
        ↪
      </button>
    </div>
  </div>

  <!-- Área editable -->
  <div
    id="editor-content"
    class="editor-content min-h-[28rem] px-6 py-6 md:px-8 md:py-7 focus:outline-none font-serif text-parchment-100 text-lg leading-[1.75]"
  ></div>
</div>

<!-- Input oculto: imágenes, vídeos y PDF -->
<input
  type="file"
  id="editor-media-input"
  accept="image/*,video/*,application/pdf,.pdf"
  class="hidden"
  aria-hidden="true"
/>

<style is:global>
  /* Tipografía del editor igual que el sitio público */
  .editor-content {
    font-family: var(--font-serif);
    color: var(--color-parchment-100);
  }
  .editor-content p {
    margin-bottom: 1.25rem;
  }
  .editor-content h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--color-parchment-50);
    margin: 2.5rem 0 1rem 0;
    line-height: 1.25;
  }
  .editor-content h3 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--color-gold-300);
    margin: 2rem 0 0.75rem 0;
  }
  .editor-content blockquote {
    border-left: 2px solid var(--color-gold-500);
    padding: 0.5rem 0 0.5rem 1.5rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-parchment-200);
  }
  .editor-content hr {
    border: none;
    text-align: center;
    margin: 2rem 0;
    color: var(--color-gold-400);
    opacity: 0.6;
  }
  .editor-content hr::after {
    content: "☉";
    font-size: 1.2rem;
  }
  .editor-content ul {
    list-style: none;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .editor-content ul li::before {
    content: "◆";
    color: var(--color-gold-500);
    font-size: 0.55rem;
    margin-right: 0.6rem;
    vertical-align: middle;
  }
  .editor-content ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .editor-content ol li {
    color: var(--color-parchment-100);
    margin-bottom: 0.4rem;
  }
  .editor-content a {
    color: var(--color-gold-300);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .editor-content strong {
    color: var(--color-parchment-50);
    font-weight: 600;
  }
  .editor-content em {
    color: var(--color-parchment-200);
  }
  .editor-content img {
    max-width: 100%;
    border-radius: 2px;
    margin: 1.5rem auto;
    display: block;
  }
  .editor-content .youtube-embed {
    margin: 1.5rem 0;
    aspect-ratio: 16/9;
    width: 100%;
  }
  .editor-content .youtube-embed iframe {
    width: 100%;
    height: 100%;
    border-radius: 2px;
  }
  .editor-content .blog-content-video {
    width: 100%;
    max-width: 100%;
    border-radius: 2px;
    margin: 1.5rem auto;
    display: block;
    background: rgb(0 0 0 / 0.35);
  }
  .editor-content .blog-pdf-block {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
    margin: 1.5rem 0;
    padding: 0.85rem 1.1rem;
    border: 1px solid rgb(212 175 55 / 0.2);
    border-radius: 2px;
    background: rgb(230 196 100 / 0.04);
  }
  .editor-content .blog-pdf-badge {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-parchment-500);
  }
  .editor-content a.blog-pdf-download {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gold-400);
    text-decoration: none;
    border-bottom: 1px solid rgb(212 175 55 / 0.28);
    padding-bottom: 1px;
  }
  .editor-content a.blog-pdf-download:hover {
    color: var(--color-gold-300);
    border-color: rgb(212 175 55 / 0.5);
  }
  .editor-content table.blog-layout-table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    border: none;
    table-layout: fixed;
  }
  .editor-content table.blog-layout-table td,
  .editor-content table.blog-layout-table th {
    border: none;
    vertical-align: top;
    padding: 0.5rem 0.75rem;
    width: 50%;
  }
  @media (max-width: 640px) {
    .editor-content table.blog-layout-table,
    .editor-content table.blog-layout-table tbody,
    .editor-content table.blog-layout-table tr {
      display: block;
      width: 100%;
    }
    .editor-content table.blog-layout-table td,
    .editor-content table.blog-layout-table th {
      display: block;
      width: 100%;
    }
  }

  /* Placeholder de Tiptap */
  .editor-content p.is-editor-empty:first-child::before {
    content: attr(data-placeholder);
    float: left;
    color: var(--color-parchment-500);
    pointer-events: none;
    height: 0;
    font-style: italic;
  }

  /* Foco visible */
  .editor-content:focus {
    outline: none;
  }
  .editor-blog-wrapper:focus-within .editor-toolbar {
    border-color: rgba(212, 175, 55, 0.25);
  }

  /* Botones de la toolbar */
  .tb-btn {
    min-width: 2rem;
    height: 2rem;
    padding: 0 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--color-parchment-300);
    background: transparent;
    border: 1px solid transparent;
    border-radius: 2px;
    cursor: pointer;
    transition: all 120ms ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .tb-btn:hover {
    color: var(--color-gold-300);
    background: rgba(212, 175, 55, 0.08);
    border-color: rgba(212, 175, 55, 0.2);
  }
  .tb-btn.is-active {
    color: var(--color-night-950);
    background: linear-gradient(180deg, var(--color-gold-300), var(--color-gold-500));
    border-color: var(--color-gold-600);
  }
  .tb-divider {
    width: 1px;
    background: rgba(212, 175, 55, 0.15);
    margin: 0.2rem 0.1rem;
    align-self: stretch;
  }
</style>

<script>
  import { Editor } from "@tiptap/core";
  import StarterKit from "@tiptap/starter-kit";
  import Image from "@tiptap/extension-image";
  import Link from "@tiptap/extension-link";
  import Placeholder from "@tiptap/extension-placeholder";
  import Youtube from "@tiptap/extension-youtube";
  import { Table } from "@tiptap/extension-table";
  import { TableRow } from "@tiptap/extension-table-row";
  import { TableCell } from "@tiptap/extension-table-cell";
  import { TableHeader } from "@tiptap/extension-table-header";
  import { Gapcursor } from "@tiptap/extension-gapcursor";
  import { BlogVideo } from "../lib/tiptap-blog-video";
  import { BlogPdf } from "../lib/tiptap-blog-pdf";
  import { supabase } from "../lib/supabase";

  const root = document.getElementById("editor-blog-root");
  const contentEl = document.getElementById("editor-content");
  const mediaInput = document.getElementById(
    "editor-media-input",
  ) as HTMLInputElement | null;

  function toastError(msg: string) {
    const toast = document.createElement("div");
    toast.className =
      "fixed bottom-6 right-6 z-[999] px-5 py-3 rounded-sm shadow-xl font-sans text-sm max-w-sm bg-wine-700 text-parchment-50";
    toast.textContent = msg;
    document.body.appendChild(toast);
    setTimeout(() => {
      toast.style.opacity = "0";
      setTimeout(() => toast.remove(), 400);
    }, 4000);
  }

  function isYoutubeUrl(url: string): boolean {
    return /youtube\.com|youtu\.be/i.test(url);
  }

  function isDirectVideoUrl(url: string): boolean {
    return /\.(mp4|webm|ogg|mov)(\?|#|$)/i.test(url);
  }

  function isPdfUrl(url: string): boolean {
    return /\.pdf(\?|#|$)/i.test(url);
  }

  function nombreDesdePdfUrl(url: string): string | null {
    try {
      const u = new URL(url);
      const seg = u.pathname.split("/").filter(Boolean).pop();
      if (!seg || !/\.pdf$/i.test(seg)) return null;
      return decodeURIComponent(seg);
    } catch {
      return null;
    }
  }

  function esArchivoPdf(file: File): boolean {
    return file.type === "application/pdf" || /\.pdf$/i.test(file.name);
  }

  if (!root || !contentEl) {
    console.error("[EditorBlog] elementos no encontrados");
  } else {
    const initialJson = JSON.parse(root.dataset.initial ?? "null");
    const placeholder = root.dataset.placeholder ?? "Comenzá a escribir…";

    const editor = new Editor({
      element: contentEl,
      extensions: [
        StarterKit.configure({
          heading: { levels: [2, 3] },
          bulletList: { keepMarks: true },
          orderedList: { keepMarks: true },
        }),
        Gapcursor,
        BlogVideo,
        BlogPdf,
        Image.configure({ inline: false, allowBase64: false }),
        Link.configure({ openOnClick: false, autolink: true }),
        Placeholder.configure({ placeholder }),
        Youtube.configure({ width: "100%", height: 400 }),
        Table.configure({
          resizable: false,
          HTMLAttributes: { class: "blog-layout-table" },
        }),
        TableRow,
        TableHeader,
        TableCell,
      ],
      content: initialJson ?? "",
      onUpdate: ({ editor: ed }) => {
        const json = ed.getJSON();
        const html = ed.getHTML();
        root.dispatchEvent(new CustomEvent("editor:change", { detail: { json, html } }));
        actualizarToolbar(ed);
      },
      onSelectionUpdate: ({ editor: ed }) => {
        actualizarToolbar(ed);
      },
    });

    // Permite que páginas externas inyecten contenido DESPUÉS de que el editor
    // ya se inicializó (necesario cuando el contenido se carga de forma async,
    // ej. editar.astro que trae el post de Supabase).
    root.addEventListener("editor:setContent", (e: Event) => {
      const { json, html } = (e as CustomEvent).detail ?? {};
      if (json) {
        editor.commands.setContent(json, false);
      } else if (html) {
        editor.commands.setContent(html, false);
      }
      root.dispatchEvent(new CustomEvent("editor:change", {
        detail: { json: editor.getJSON(), html: editor.getHTML() },
      }));
    });

    // ----------------------------------------------------------------
    // Toolbar: comandos
    // ----------------------------------------------------------------
    function actualizarToolbar(ed: typeof editor) {
      document.querySelectorAll<HTMLButtonElement>("[data-cmd]").forEach((btn) => {
        const cmd = btn.dataset.cmd!;
        const isActive =
          cmd === "bold" ? ed.isActive("bold")
          : cmd === "italic" ? ed.isActive("italic")
          : cmd === "h2" ? ed.isActive("heading", { level: 2 })
          : cmd === "h3" ? ed.isActive("heading", { level: 3 })
          : cmd === "blockquote" ? ed.isActive("blockquote")
          : cmd === "bulletList" ? ed.isActive("bulletList")
          : cmd === "orderedList" ? ed.isActive("orderedList")
          : false;
        btn.classList.toggle("is-active", isActive);
      });
    }

    document.querySelectorAll<HTMLButtonElement>("[data-cmd]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const cmd = btn.dataset.cmd!;
        switch (cmd) {
          case "bold":
            editor.chain().focus().toggleBold().run();
            break;
          case "italic":
            editor.chain().focus().toggleItalic().run();
            break;
          case "h2":
            editor.chain().focus().toggleHeading({ level: 2 }).run();
            break;
          case "h3":
            editor.chain().focus().toggleHeading({ level: 3 }).run();
            break;
          case "blockquote":
            editor.chain().focus().toggleBlockquote().run();
            break;
          case "bulletList":
            editor.chain().focus().toggleBulletList().run();
            break;
          case "orderedList":
            editor.chain().focus().toggleOrderedList().run();
            break;
          case "horizontalRule":
            editor.chain().focus().setHorizontalRule().run();
            break;
          case "undo":
            editor.chain().focus().undo().run();
            break;
          case "redo":
            editor.chain().focus().redo().run();
            break;
          case "link": {
            // Prompt personalizado inline
            const prevUrl = editor.getAttributes("link").href ?? "";
            const input = document.createElement("div");
            input.className = "fixed inset-0 z-[998] flex items-center justify-center bg-night-950/80 backdrop-blur-sm";
            input.innerHTML = `
              <div class="card-altar p-6 max-w-sm w-full mx-4 space-y-4">
                <p class="text-[11px] uppercase tracking-widest text-parchment-400">URL del link</p>
                <input id="link-url-input" type="url" value="${prevUrl}"
                  placeholder="https://..."
                  class="w-full bg-night-950/60 border border-gold-400/15 focus:border-gold-400/60 outline-none text-parchment-100 px-3 py-2 text-sm font-sans rounded-sm"/>
                <div class="flex gap-2 justify-end">
                  <button id="link-cancel" class="btn-ghost text-xs">Cancelar</button>
                  <button id="link-remove" class="text-[11px] uppercase tracking-widest text-wine-400 hover:text-wine-300 px-3 py-1.5">Quitar link</button>
                  <button id="link-ok" class="btn-gold text-xs">Aplicar</button>
                </div>
              </div>`;
            document.body.appendChild(input);
            const urlInput = input.querySelector("#link-url-input") as HTMLInputElement;
            urlInput?.focus();
            input.querySelector("#link-ok")?.addEventListener("click", () => {
              const url = urlInput.value.trim();
              if (url) editor.chain().focus().setLink({ href: url }).run();
              input.remove();
            });
            input.querySelector("#link-remove")?.addEventListener("click", () => {
              editor.chain().focus().unsetLink().run();
              input.remove();
            });
            input.querySelector("#link-cancel")?.addEventListener("click", () => input.remove());
            urlInput?.addEventListener("keydown", (e) => {
              if (e.key === "Enter") { const url = urlInput.value.trim(); if (url) editor.chain().focus().setLink({ href: url }).run(); input.remove(); }
              if (e.key === "Escape") input.remove();
            });
            break;
          }
          case "media":
            mediaInput?.click();
            break;
          case "mediaUrl": {
            const modal = document.createElement("div");
            modal.className =
              "fixed inset-0 z-[998] flex items-center justify-center bg-night-950/80 backdrop-blur-sm";
            modal.innerHTML = `
              <div class="card-altar p-6 max-w-md w-full mx-4 space-y-4">
                <p class="font-display text-base text-parchment-100">Insertar desde URL</p>
                <p class="text-xs text-parchment-500 leading-relaxed">
                  Imagen, PDF, vídeo (.mp4, .webm…) o URL de YouTube.
                </p>
                <input id="media-url-input" type="url" placeholder="https://…"
                  class="w-full bg-night-950/60 border border-gold-400/15 focus:border-gold-400/60 outline-none text-parchment-100 px-3 py-2 text-sm font-sans rounded-sm"/>
                <div class="flex gap-2 justify-end">
                  <button id="media-cancel" class="btn-ghost text-xs">Cancelar</button>
                  <button id="media-ok" class="btn-gold text-xs">Insertar</button>
                </div>
              </div>`;
            document.body.appendChild(modal);
            const urlField = modal.querySelector("#media-url-input") as HTMLInputElement;
            const aplicarUrl = () => {
              const url = urlField.value.trim();
              if (!url) return;
              if (isYoutubeUrl(url)) {
                editor.chain().focus().setYoutubeVideo({ src: url }).run();
              } else if (isPdfUrl(url)) {
                const nombre = nombreDesdePdfUrl(url);
                editor.chain().focus().setBlogPdf({ url, nombre }).run();
              } else if (isDirectVideoUrl(url)) {
                editor.chain().focus().setBlogVideo({ src: url }).run();
              } else {
                editor.chain().focus().setImage({ src: url }).run();
              }
              modal.remove();
            };
            modal.querySelector("#media-ok")?.addEventListener("click", aplicarUrl);
            modal.querySelector("#media-cancel")?.addEventListener("click", () => modal.remove());
            modal.addEventListener("click", (ev) => {
              if (ev.target === modal) modal.remove();
            });
            urlField?.focus();
            urlField?.addEventListener("keydown", (e) => {
              if (e.key === "Enter") aplicarUrl();
              if (e.key === "Escape") modal.remove();
            });
            break;
          }
          case "twoCol":
            editor.chain().focus().insertTable({ rows: 1, cols: 2, withHeaderRow: false }).run();
            break;
        }
      });
    });

    async function subirMedioEInsertar(file: File) {
      const ext = file.name.split(".").pop() ?? "bin";
      const path = `${Date.now()}-${Math.random().toString(36).slice(2)}.${ext}`;

      const { error } = await supabase.storage
        .from("blog-images")
        .upload(path, file, {
          upsert: false,
          contentType:
            file.type
            || (esArchivoPdf(file) ? "application/pdf" : "application/octet-stream"),
        });

      if (error) {
        toastError(`No se pudo subir el archivo: ${error.message}`);
        return;
      }

      const { data: urlData } = supabase.storage.from("blog-images").getPublicUrl(path);
      const pub = urlData?.publicUrl;
      if (!pub) return;

      if (esArchivoPdf(file)) {
        editor.chain().focus().setBlogPdf({ url: pub, nombre: file.name }).run();
      } else if (file.type.startsWith("video/")) {
        editor.chain().focus().setBlogVideo({ src: pub }).run();
      } else {
        editor.chain().focus().setImage({ src: pub }).run();
      }
    }

    mediaInput?.addEventListener("change", async () => {
      const file = mediaInput.files?.[0];
      if (!file) return;
      await subirMedioEInsertar(file);
      mediaInput.value = "";
    });
  }
</script>
