---
const links = [
  { href: "/", label: "Inicio" },
  { href: "/cursos", label: "Cursos" },
  { href: "/blog", label: "Blog" },
  { href: "/tradicion", label: "La Tradición" },
  { href: "/contacto", label: "Contacto" },
];

const pathname = new URL(Astro.request.url).pathname.replace(/\/$/, "") || "/";
---

<header class="sticky top-0 z-50 border-b border-[rgb(230_196_100_/_0.12)] bg-[rgb(7_6_13_/_0.85)] backdrop-blur-md">
  <div class="container-prose flex items-center justify-between py-4">
    <a href="/" class="flex items-center gap-3 group">
      <span class="text-xl text-[color:var(--color-gold-400)] transition-colors group-hover:text-[color:var(--color-gold-300)]">☉</span>
      <span class="font-display text-sm tracking-[0.25em] uppercase text-parchment-50">
        Tradición Mística<span class="text-[color:var(--color-gold-400)]"> · </span>Hermética
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {
        links.map((link) => {
          const isActive = pathname === link.href || (link.href !== "/" && pathname.startsWith(link.href));
          return (
            <a
              href={link.href}
              class:list={[
                "nav-link text-[0.78rem] tracking-[0.2em] uppercase font-medium",
                isActive ? "is-active" : "",
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>

    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-parchment-100"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="4" y1="7" x2="20" y2="7" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-[rgb(230_196_100_/_0.12)] bg-[color:var(--color-night-900)]"
  >
    <nav class="container-prose flex flex-col py-4 gap-4">
      {
        links.map((link) => {
          const isActive = pathname === link.href || (link.href !== "/" && pathname.startsWith(link.href));
          return (
            <a
              href={link.href}
              class:list={[
                "nav-link nav-link--mobile text-sm tracking-[0.2em] uppercase font-medium",
                isActive ? "is-active" : "",
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>
  </div>

  <style>
    .nav-link {
      position: relative;
      display: inline-block;
      padding: 0.25rem 0.1rem;
      color: var(--color-parchment-200);
      transition:
        color 200ms ease,
        text-shadow 320ms ease;
    }

    /* Linea dorada que se dibuja de adentro hacia afuera */
    .nav-link::after {
      content: "";
      position: absolute;
      left: 50%;
      right: 50%;
      bottom: -0.35rem;
      height: 1px;
      background: linear-gradient(
        to right,
        transparent,
        var(--color-gold-400),
        transparent
      );
      opacity: 0;
      transition:
        left 320ms cubic-bezier(0.4, 0, 0.2, 1),
        right 320ms cubic-bezier(0.4, 0, 0.2, 1),
        opacity 240ms ease;
    }

    .nav-link:hover,
    .nav-link:focus-visible {
      color: var(--color-gold-300);
      text-shadow:
        0 0 14px rgb(230 196 100 / 0.35),
        0 0 24px rgb(212 175 55 / 0.18);
    }

    .nav-link:hover::after,
    .nav-link:focus-visible::after,
    .nav-link.is-active::after {
      left: 0;
      right: 0;
      opacity: 1;
    }

    .nav-link.is-active {
      color: var(--color-gold-400);
      text-shadow: 0 0 12px rgb(230 196 100 / 0.3);
    }

    /* Menu mobile: mismo tratamiento pero sin el transición por ancho
       (en mobile el link es full-width, queda feo el subrayado que se expande). */
    .nav-link--mobile {
      color: var(--color-parchment-100);
    }

    .nav-link--mobile::after {
      display: none;
    }
  </style>
</header>

<script is:inline>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  if (btn && menu) {
    btn.addEventListener("click", () => {
      const isHidden = menu.classList.contains("hidden");
      menu.classList.toggle("hidden");
      btn.setAttribute("aria-expanded", String(isHidden));
    });
  }
</script>
