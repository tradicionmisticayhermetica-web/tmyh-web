---
/**
 * Loader global del sitio. Disponible en cualquier página que incluya
 * BaseLayout o AdminLayout.
 *
 * Animación:
 *   - Mercurio (☿), Azufre (🜍) y Sal (🜔) en posiciones triangulares que
 *     rotan suavemente alrededor del centro.
 *   - Convergen al centro y se funden en el Sol (☉), que pulsa con un
 *     halo dorado.
 *   - El Sol se desvanece y los 3 símbolos vuelven a emerger hacia las
 *     posiciones triangulares. Loop infinito.
 *
 * API global:
 *   window.__tmyhLoader.show(message?: string)
 *   window.__tmyhLoader.hide()
 *
 * Tiene watchdog de 15s: si nadie llama hide(), se oculta solo y loguea
 * un warning para que no quede nunca colgado.
 */
---

<div
  id="tmyh-loader"
  class="hidden fixed inset-0 z-[1300] items-center justify-center bg-night-950/80 backdrop-blur-[2px]"
  role="status"
  aria-live="polite"
  aria-label="Procesando"
>
  <div class="card-altar px-9 py-8 text-center min-w-[300px]">
    <div class="loader-orb" aria-hidden="true">
      <span class="loader-orb-particle m">☿</span>
      <span class="loader-orb-particle a">🜍</span>
      <span class="loader-orb-particle s">🜔</span>
      <span class="loader-orb-sun">☉</span>
    </div>
    <p
      id="tmyh-loader-text"
      class="mt-6 text-xs tracking-[0.22em] uppercase text-parchment-200"
    >
      Procesando…
    </p>
  </div>
</div>

<style is:global>
  .loader-orb {
    position: relative;
    width: 6rem;
    height: 6rem;
    margin: 0 auto;
    animation: loader-orb-spin 7.2s linear infinite;
  }
  .loader-orb-particle {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 2.2rem;
    height: 2.2rem;
    margin: -1.1rem 0 0 -1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.55rem;
    color: var(--color-gold-300);
    text-shadow: 0 0 12px rgb(230 196 100 / 0.45);
    animation-duration: 3.6s;
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
    will-change: transform, opacity;
  }
  .loader-orb-particle.m {
    animation-name: loader-orb-mercury;
  }
  .loader-orb-particle.a {
    animation-name: loader-orb-azufre;
    animation-delay: 0.05s;
  }
  .loader-orb-particle.s {
    animation-name: loader-orb-sal;
    animation-delay: 0.1s;
  }
  .loader-orb-sun {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 2.6rem;
    height: 2.6rem;
    margin: -1.3rem 0 0 -1.3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: var(--color-gold-200);
    text-shadow:
      0 0 6px rgb(230 196 100 / 0.75),
      0 0 18px rgb(230 196 100 / 0.5),
      0 0 32px rgb(230 196 100 / 0.28);
    opacity: 0;
    animation: loader-orb-sun 3.6s ease-in-out infinite;
    will-change: transform, opacity;
  }

  @keyframes loader-orb-spin {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }
  @keyframes loader-orb-mercury {
    0%,
    14% {
      transform: translate(0, -1.95rem) scale(1);
      opacity: 1;
    }
    35% {
      transform: translate(0, -0.1rem) scale(0.55);
      opacity: 0;
    }
    62% {
      transform: translate(0, -0.1rem) scale(0.55);
      opacity: 0;
    }
    82% {
      transform: translate(0, -1rem) scale(0.85);
      opacity: 0.45;
    }
    100% {
      transform: translate(0, -1.95rem) scale(1);
      opacity: 1;
    }
  }
  @keyframes loader-orb-azufre {
    0%,
    14% {
      transform: translate(1.7rem, 0.97rem) scale(1);
      opacity: 1;
    }
    35% {
      transform: translate(0.1rem, 0.06rem) scale(0.55);
      opacity: 0;
    }
    62% {
      transform: translate(0.1rem, 0.06rem) scale(0.55);
      opacity: 0;
    }
    82% {
      transform: translate(0.85rem, 0.5rem) scale(0.85);
      opacity: 0.45;
    }
    100% {
      transform: translate(1.7rem, 0.97rem) scale(1);
      opacity: 1;
    }
  }
  @keyframes loader-orb-sal {
    0%,
    14% {
      transform: translate(-1.7rem, 0.97rem) scale(1);
      opacity: 1;
    }
    35% {
      transform: translate(-0.1rem, 0.06rem) scale(0.55);
      opacity: 0;
    }
    62% {
      transform: translate(-0.1rem, 0.06rem) scale(0.55);
      opacity: 0;
    }
    82% {
      transform: translate(-0.85rem, 0.5rem) scale(0.85);
      opacity: 0.45;
    }
    100% {
      transform: translate(-1.7rem, 0.97rem) scale(1);
      opacity: 1;
    }
  }
  @keyframes loader-orb-sun {
    0%,
    28% {
      opacity: 0;
      transform: scale(0.35);
    }
    42% {
      opacity: 1;
      transform: scale(1);
    }
    52% {
      opacity: 1;
      transform: scale(1.18);
    }
    66% {
      opacity: 0;
      transform: scale(1.4);
    }
    100% {
      opacity: 0;
      transform: scale(0.35);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .loader-orb,
    .loader-orb-particle,
    .loader-orb-sun {
      animation-duration: 0s;
      animation: none;
    }
    .loader-orb-sun {
      opacity: 1;
    }
    .loader-orb-particle {
      opacity: 0.6;
    }
  }
</style>

<script is:inline>
  // is:inline garantiza ejecución sincrónica en el orden del HTML.
  // El div #tmyh-loader ya existe en el DOM en este punto, así que
  // window.__tmyhLoader queda disponible antes de cualquier otro
  // <script> de página hija (incluso los que usan top-level await).
  (function () {
    const loaderWrap = document.getElementById("tmyh-loader");
    const loaderText = document.getElementById("tmyh-loader-text");
    let watchdog = null;

    const tmyhLoader = {
      show: function (message) {
        if (loaderText) loaderText.textContent = message || "Procesando…";
        if (loaderWrap) {
          loaderWrap.classList.remove("hidden");
          loaderWrap.classList.add("flex");
        }
        if (watchdog) clearTimeout(watchdog);
        watchdog = setTimeout(function () {
          tmyhLoader.hide();
          console.warn("[loader] watchdog activado: 15s sin hide()");
        }, 15000);
      },
      hide: function () {
        if (watchdog) {
          clearTimeout(watchdog);
          watchdog = null;
        }
        if (loaderWrap) {
          loaderWrap.classList.add("hidden");
          loaderWrap.classList.remove("flex");
        }
      },
    };

    window.__tmyhLoader = tmyhLoader;
  })();
</script>
