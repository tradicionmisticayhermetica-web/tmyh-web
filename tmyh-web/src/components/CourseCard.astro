---
import type { Curso } from "../data/cursos";

interface Props {
  curso: Curso;
}

const { curso } = Astro.props;
---

<a
  href={`/cursos/${curso.slug}`}
  class="card-altar group block p-8 relative overflow-hidden"
>
  <div class="absolute top-6 right-6 text-4xl text-[color:var(--color-gold-500)] opacity-30 transition-opacity group-hover:opacity-60">
    {curso.simbolo}
  </div>

  <div class="flex items-center gap-2 mb-5">
    <span class="title-eyebrow !border-none !pb-0">
      {curso.estado === "proximo"
        ? "Próximamente"
        : (curso.estado === "historico" || curso.estado === "edicion_cerrada")
          ? "Edición cerrada"
          : "Activo"}
    </span>
    <span class="text-xs text-parchment-400">·</span>
    <span class="text-xs text-parchment-400">{curso.clases} clases</span>
  </div>

  <h3 class="text-2xl font-display mb-3 text-parchment-50 group-hover:text-[color:var(--color-gold-300)] transition-colors">
    {curso.titulo}
  </h3>

  <p class="text-sm leading-relaxed text-parchment-200 mb-6">
    {curso.descripcionCorta}
  </p>

  <div class="flex items-center justify-between pt-5 border-t border-[rgb(230_196_100_/_0.1)]">
    <span class="text-xs tracking-wider text-parchment-400 uppercase">
      {curso.modalidad}
    </span>
    <span class="text-xs tracking-[0.2em] uppercase text-[color:var(--color-gold-400)] group-hover:text-[color:var(--color-gold-300)]">
      Ver detalle →
    </span>
  </div>
</a>
