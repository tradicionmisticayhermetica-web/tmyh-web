# =============================================================================
# Variables de entorno para tmyh-web (Astro + Supabase)
# =============================================================================
# Copiar este archivo como `.env` y completar los valores reales.
# NUNCA subir `.env` al repo. Solo sube `.env.example` (este archivo).
#
# Se usan en el navegador (por eso el prefijo PUBLIC_). Son seguras de
# exponer porque:
#  - Las tablas tienen RLS activo y no hay policies abiertas.
#  - El formulario de contacto solo puede llamar a la RPC
#    `enviar_mensaje_contacto` (security definer), no a las tablas.
#
# Donde conseguirlas:
#   Supabase Dashboard -> tu proyecto -> Project Settings -> API -> Project URL
#   Supabase Dashboard -> tu proyecto -> Project Settings -> API -> anon public
# =============================================================================

PUBLIC_SUPABASE_URL=https://<tu-proyecto>.supabase.co
PUBLIC_SUPABASE_ANON_KEY=<pega-aqui-la-anon-public-key>
