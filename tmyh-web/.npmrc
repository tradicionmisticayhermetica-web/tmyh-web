# =============================================================================
# Configuracion de pnpm para tmyh-web
# =============================================================================
# Este archivo solo lo lee pnpm (no npm). Define como instalamos paquetes y
# que mitigaciones de seguridad aplicamos contra ataques al npm registry
# (Shai-Hulud, Axios RAT, TanStack hijack, etc.).
# =============================================================================

# -----------------------------------------------------------------------------
# Cuarentena de 14 dias para versiones recien publicadas
# -----------------------------------------------------------------------------
# pnpm ignora versiones publicadas en el registry hace menos de 20160 minutos
# (= 14 dias) y se queda con la ultima estable anterior. Si manana se publica
# una version troyanizada de cualquier dependencia, no se instala hasta que
# pase la cuarentena -- tiempo de sobra para que los advisories detecten el
# ataque y se purgue del registry.
#
# Esta es la mitigacion #1 contra supply-chain attacks via npm registry.
# -----------------------------------------------------------------------------
minimum-release-age=20160

# -----------------------------------------------------------------------------
# Resolucion de peer dependencies
# -----------------------------------------------------------------------------
# auto-install-peers: instala automaticamente las peers que falten.
# strict-peer-dependencies: si una peer no matchea no rompemos el install
# (avisa con warning). En produccion preferimos seguir antes que romper.
# -----------------------------------------------------------------------------
auto-install-peers=true
strict-peer-dependencies=false

# -----------------------------------------------------------------------------
# Compatibilidad con tooling que asume estructura plana (npm-style)
# -----------------------------------------------------------------------------
# shamefully-hoist=true expone todas las transitivas en el top-level del
# node_modules, igual que npm. Sacrifica el aislamiento estricto de pnpm a
# cambio de compatibilidad con herramientas (Vite, Astro, Tailwind) que aun
# asumen "phantom dependencies".
#
# Una vez que el ecosistema mejore esto podriamos volver a false para ganar
# aislamiento real.
# -----------------------------------------------------------------------------
shamefully-hoist=true
