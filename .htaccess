# =============================================================================
# .htaccess — Tradición Mística y Hermética
#
# Este archivo va al public_html de Ferozo (junto al index.html del sitio
# nuevo). Cumple tres funciones:
#
#   1. Forzar HTTPS y dominio canónico (sin "www" duplicado, etc.).
#   2. Redirigir 301 las URLs antiguas del WordPress hacia las rutas nuevas
#      del sitio Astro, para no perder tráfico ni autoridad SEO.
#   3. Compresión y cache de assets estáticos.
#
# IMPORTANTE: el listado de redirects 301 debajo es un punto de partida.
# Cuando Search Console te dé el inventario real de URLs con tráfico, agregá
# o ajustá las líneas correspondientes. Las rutas que NO matcheen ninguna
# regla específica caen en /404, lo cual también es informativo para Google.
# =============================================================================

# -----------------------------------------------------------------------------
# 1) HTTPS + dominio canónico
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Forzar HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # Forzar www (si querés sin-www, invertir)
  RewriteCond %{HTTP_HOST} ^tradicionmisticayhermetica\.com$ [NC]
  RewriteRule ^(.*)$ https://www.tradicionmisticayhermetica.com/$1 [R=301,L]
</IfModule>

# -----------------------------------------------------------------------------
# 2) Redirects 301 desde URLs viejas de WordPress
# -----------------------------------------------------------------------------
# Estructura típica de WordPress:
#   /año/mes/dia/nombre-del-post/   → /blog/post?slug=nombre-del-post
#   /?page_id=123                   → mapeo manual
#   /?p=123                         → mapeo manual
#   /category/...                   → /blog/
#   /tag/...                        → /blog/
#   /author/...                     → /
#
# Editá esta sección con los slugs reales que tengan tráfico (Search Console
# > Páginas, ordenado por clics o impresiones).

# 2.a) Posts del blog WordPress (formato /YYYY/MM/DD/slug/)
# Si todos los slugs viejos coinciden con los nuevos, esta regla redirige todo.
RedirectMatch 301 ^/[0-9]{4}/[0-9]{2}/[0-9]{2}/([^/]+)/?$ /blog/post?slug=$1

# 2.b) Posts del blog WordPress (formato /YYYY/MM/slug/)
RedirectMatch 301 ^/[0-9]{4}/[0-9]{2}/([^/]+)/?$ /blog/post?slug=$1

# 2.c) Categorías y tags → al índice del blog
RedirectMatch 301 ^/category/.*$ /blog
RedirectMatch 301 ^/tag/.*$ /blog

# 2.d) Páginas de autor → home
RedirectMatch 301 ^/author/.*$ /

# 2.e) URLs específicas (ejemplo, ajustá según inventario)
# Redirect 301 /quien-soy /tradicion
# Redirect 301 /sobre-mi /tradicion
# Redirect 301 /escuela /tradicion
# Redirect 301 /mis-cursos /cursos
# Redirect 301 /servicios /cursos
# Redirect 301 /contactanos /contacto

# 2.f) Feeds de WordPress
RedirectMatch 301 ^/feed/?$ /blog
RedirectMatch 301 ^/comments/feed/?$ /blog

# 2.g) Búsquedas de WordPress
RedirectMatch 301 ^/\?s=.*$ /blog

# -----------------------------------------------------------------------------
# 3) Compresión gzip
# -----------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# -----------------------------------------------------------------------------
# 4) Cache de assets estáticos
# -----------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — sin cache agresiva para que los cambios se vean rápido
  ExpiresByType text/html "access plus 0 seconds"

  # CSS y JS hash-buildeados por Astro — un año (Astro pone hashes en _astro/)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"

  # Imágenes y fuentes — un mes
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

# -----------------------------------------------------------------------------
# 5) Páginas custom de error
# -----------------------------------------------------------------------------
ErrorDocument 404 /404/index.html

# -----------------------------------------------------------------------------
# 6) Bloquear acceso a archivos sensibles
# -----------------------------------------------------------------------------
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

<FilesMatch "(README|CHANGELOG|LICENSE|composer\.json|package\.json|package-lock\.json)">
  Require all denied
</FilesMatch>
